    function safeRivet(ctx, clipPath, x, y, r) {
      if (
        ctx.isPointInPath(clipPath, x, y) &&
        ctx.isPointInPath(clipPath, x - r, y) &&
        ctx.isPointInPath(clipPath, x + r, y) &&
        ctx.isPointInPath(clipPath, x, y - r) &&
        ctx.isPointInPath(clipPath, x, y + r)
      ) {
        drawRivet(ctx, x, y, r);
      }
    }

    function drawFixedEdgeDecorations(ctx, width, height, cfg, clipPath, rng) {
      var sx = width / 640;
      var sy = height / 480;
      var guard = Math.max(2, cfg.offset * 0.75);
      var leftMin = cfg.offset + cfg.topLeft.v + guard;
      var leftMax = height - cfg.offset - cfg.bottomLeft.v - guard;
      var rightMin = cfg.offset + cfg.topRight.v + guard;
      var rightMax = height - cfg.offset - cfg.bottomRight.v - guard;

      function clippedRange(baseY, baseH, minY, maxY) {
        var y1 = Math.max(baseY * sy, minY);
        var y2 = Math.min((baseY + baseH) * sy, maxY);
        return { y: y1, h: Math.max(0, y2 - y1) };
      }

      var leftVent = clippedRange(59, 147, leftMin, leftMax);
      drawSideVent(ctx, 1 * sx, leftVent.y, 30 * sx, leftVent.h, -1);

      var rightVent = clippedRange(59, 147, rightMin, rightMax);
      drawSideVent(ctx, 608 * sx, rightVent.y, 31 * sx, rightVent.h, 1);

      var hazard = clippedRange(235, 128, leftMin, leftMax);
      drawSideHazardStrip(ctx, 0, hazard.y, 14 * sx, hazard.h, rng);

      var rivets = [];
      var rx;
      for (rx = 38; rx <= 604; rx += 190) { rivets.push([rx, 38, 4.1]); }
      for (rx = 38; rx <= 604; rx += 190) { rivets.push([rx, 451, 4.2]); }
      rivets.push([217, 37, 4.2], [414, 38, 4.2], [606, 231, 4.7], [604, 404, 4.7], [35, 230, 4.5], [217, 452, 4.2], [415, 452, 4.2], [217, 161, 3.3], [414, 160, 3.3], [320, 240, 2.8], [500, 254, 3.0]);
      for (var ri = 0; ri < rivets.length; ri += 1) {
        safeRivet(ctx, clipPath, rivets[ri][0] * sx, rivets[ri][1] * sy, rivets[ri][2] * Math.min(sx, sy));
