    }

    function drawTechMetalBackground(ctx, width, height, seed) {
      var rng = createRng(seed);
      var sx = width / 640;
      var sy = height / 480;
      ctx.save();
      ctx.scale(sx, sy);

      var backdrop = ctx.createLinearGradient(0, 0, 640, 480);
      backdrop.addColorStop(0, "#07080b");
      backdrop.addColorStop(0.45, "#15191e");
      backdrop.addColorStop(1, "#030405");
      ctx.fillStyle = backdrop;
      ctx.fillRect(0, 0, 640, 480);

      var f = { x: 8, y: 10, w: 624, h: 458, r: 23 };
      ctx.save();
      roundedPath(ctx, f.x, f.y, f.w, f.h, f.r);
      var frameFill = ctx.createLinearGradient(f.x, f.y, f.x, f.y + f.h);
      frameFill.addColorStop(0, "#1e2223");
      frameFill.addColorStop(0.08, "#a9aaa4");
      frameFill.addColorStop(0.16, "#2d3030");
      frameFill.addColorStop(0.5, "#111314");
      frameFill.addColorStop(0.88, "#8b8c87");
      frameFill.addColorStop(1, "#161819");
      ctx.fillStyle = frameFill;
      ctx.fill();
      ctx.clip();
      drawBrushedLines(ctx, rng, f.x, f.y, f.w, f.h, 180, 0.16, true);
      ctx.restore();

      metalStroke(ctx, function() { roundedPath(ctx, f.x + 2, f.y + 2, f.w - 4, f.h - 4, f.r - 2); }, 9, "#111314", 18, "rgba(0,0,0,.9)");
      metalStroke(ctx, function() { roundedPath(ctx, f.x + 7, f.y + 7, f.w - 14, f.h - 14, f.r - 7); }, 4, "#d2d2cd", 4, "rgba(255,255,255,.25)");
      metalStroke(ctx, function() { roundedPath(ctx, f.x + 13, f.y + 13, f.w - 26, f.h - 26, f.r - 11); }, 5, "#070809", 0);
      metalStroke(ctx, function() { roundedPath(ctx, f.x + 20, f.y + 20, f.w - 40, f.h - 40, f.r - 15); }, 2, "rgba(255,255,255,.35)", 0);

      var p = { x: 28, y: 32, w: 584, h: 418, r: 9 };
      ctx.save();
      roundedPath(ctx, p.x, p.y, p.w, p.h, p.r);
      var plateFill = ctx.createLinearGradient(p.x, p.y, p.x + p.w, p.y + p.h);
      plateFill.addColorStop(0, "#464947");
      plateFill.addColorStop(0.22, "#343838");
      plateFill.addColorStop(0.55, "#222629");
      plateFill.addColorStop(1, "#111416");
      ctx.fillStyle = plateFill;
      ctx.fill();
      ctx.clip();

      var glow = ctx.createRadialGradient(p.x + (p.w * 0.43), p.y + (p.h * 0.35), 0, p.x + (p.w * 0.43), p.y + (p.h * 0.35), p.w * 0.72);
      glow.addColorStop(0, "rgba(255,255,255,.13)");
      glow.addColorStop(0.38, "rgba(190,205,205,.04)");
      glow.addColorStop(1, "rgba(0,0,0,.35)");
      ctx.fillStyle = glow;
      ctx.fillRect(p.x, p.y, p.w, p.h);
      drawCloudyMetal(ctx, rng, p.x, p.y, p.w, p.h);
      drawBrushedLines(ctx, rng, p.x, p.y, p.w, p.h, 520, 0.13, false);

      for (var ti = 0; ti < 1400; ti += 1) {
        var v = rng.int(0, 255);
        var a = rng.range(0.012, 0.038);
        ctx.fillStyle = "rgba(" + v + "," + v + "," + v + "," + a + ")";
        ctx.fillRect(rng.range(p.x, p.x + p.w), rng.range(p.y, p.y + p.h), rng.range(0.6, 1.8), rng.range(0.6, 1.8));
      }

      for (var pi = 0; pi < 72; pi += 1) {
        drawPit(ctx, rng, rng.range(p.x + 30, p.x + p.w - 30), rng.range(p.y + 35, p.y + p.h - 35), rng.range(1.2, 3.2));
      }
      drawScratchCluster(ctx, rng, 150, 318, 72, 14);
      drawScratchCluster(ctx, rng, 450, 340, 70, 8);
      drawScratchCluster(ctx, rng, 530, 112, 56, 8);
      drawScratchCluster(ctx, rng, 210, 95, 70, 10);
      ctx.restore();

      metalStroke(ctx, function() { roundedPath(ctx, p.x, p.y, p.w, p.h, p.r); }, 7, "rgba(0,0,0,.82)", 10, "rgba(0,0,0,.85)");
      metalStroke(ctx, function() { roundedPath(ctx, p.x + 3, p.y + 3, p.w - 6, p.h - 6, p.r - 2); }, 2, "rgba(196,198,192,.7)", 0);
      metalStroke(ctx, function() { roundedPath(ctx, p.x + 9, p.y + 9, p.w - 18, p.h - 18, p.r - 4); }, 2, "rgba(0,0,0,.95)", 0);

      ctx.save();
      var bullet = ctx.createRadialGradient(149, 322, 0, 152, 326, 25);
      bullet.addColorStop(0, "#d2d0c7");
      bullet.addColorStop(0.2, "#202020");
      bullet.addColorStop(0.52, "#030303");
      bullet.addColorStop(1, "rgba(0,0,0,0)");
      ctx.fillStyle = bullet;
      ctx.beginPath();
      ctx.arc(152, 326, 18, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();

      var anchors = [[69,155,70], [218,45,48], [414,45,62], [462,220,75], [500,254,48], [590,90,78], [84,318,60], [565,366,48]];
      ctx.save();
      ctx.lineCap = "round";
      for (var gi = 0; gi < anchors.length; gi += 1) {
        var ax = anchors[gi][0];
        var ay = anchors[gi][1];
        var len = anchors[gi][2];
        var grime = ctx.createLinearGradient(ax, ay, ax, ay + len);
        grime.addColorStop(0, "rgba(56,72,32,.5)");
        grime.addColorStop(0.5, "rgba(42,61,24,.25)");
        grime.addColorStop(1, "rgba(42,61,24,0)");
        ctx.strokeStyle = grime;
        ctx.lineWidth = rng.range(2, 4);
        ctx.beginPath();
        ctx.moveTo(ax, ay);
        ctx.bezierCurveTo(ax + rng.range(-5, 5), ay + (len * 0.25), ax + rng.range(-6, 6), ay + (len * 0.6), ax + rng.range(-4, 4), ay + len);
        ctx.stroke();
      }
      ctx.restore();

      ctx.save();
      ctx.globalCompositeOperation = "screen";
      ctx.globalAlpha = 0.22;
      var shine = ctx.createLinearGradient(0, 0, 0, 480);
      shine.addColorStop(0, "#ffffff");
      shine.addColorStop(0.08, "rgba(255,255,255,0)");
      shine.addColorStop(0.92, "rgba(255,255,255,0)");
      shine.addColorStop(1, "#ffffff");
      ctx.fillStyle = shine;
      ctx.fillRect(0, 0, 640, 480);
      ctx.restore();

      ctx.save();
      ctx.globalCompositeOperation = "multiply";
      var vignette = ctx.createRadialGradient(320, 230, 80, 320, 230, 420);
      vignette.addColorStop(0, "rgba(0,0,0,0)");
      vignette.addColorStop(1, "rgba(0,0,0,.38)");
      ctx.fillStyle = vignette;
      ctx.fillRect(0, 0, 640, 480);
      ctx.restore();

      ctx.restore();
    }

    function drawShapeMetalFrame(ctx, path, width, height, borderWidth, shadowColor) {
      if (!Number.isFinite(borderWidth) || borderWidth <= 0) {
        return;
      }

      var outer = ctx.createLinearGradient(0, 0, width, height);
      outer.addColorStop(0, "#141718");
      outer.addColorStop(0.12, "#d0d0c9");
      outer.addColorStop(0.28, "#4a4d4b");
      outer.addColorStop(0.52, "#08090a");
      outer.addColorStop(0.78, "#9b9c96");
      outer.addColorStop(1, "#101213");

      var bevel = ctx.createLinearGradient(0, 0, 0, height);
      bevel.addColorStop(0, "rgba(255,255,255,.88)");
      bevel.addColorStop(0.22, "rgba(25,27,28,.82)");
      bevel.addColorStop(0.72, "rgba(8,9,10,.92)");
      bevel.addColorStop(1, "rgba(230,230,220,.55)");

      ctx.save();
      ctx.lineJoin = "round";
      ctx.lineCap = "round";

      ctx.shadowColor = shadowColor || "rgba(0,0,0,.8)";
      ctx.shadowBlur = Math.max(8, borderWidth * 1.15);
      ctx.lineWidth = borderWidth;
      ctx.strokeStyle = "rgba(0,0,0,.72)";
      ctx.stroke(path);

      ctx.shadowBlur = 0;
      ctx.lineWidth = Math.max(1, borderWidth * 0.86);
      ctx.strokeStyle = outer;
      ctx.stroke(path);

      ctx.lineWidth = Math.max(1, borderWidth * 0.48);
      ctx.strokeStyle = "rgba(6,7,8,.72)";
      ctx.stroke(path);

      ctx.lineWidth = Math.max(1, borderWidth * 0.18);
      ctx.strokeStyle = bevel;
      ctx.stroke(path);
      ctx.restore();
    }

    var ctx = this.context;
    var canvasWidth = this.width;
    var canvasHeight = this.height;
    var borderWidth = Math.max(0, normalizeCssValue(this.borderWidth, canvasWidth, 5));
    var patternSize = Math.max(1, normalizeCssValue(this.patternSize, canvasWidth, 20));
