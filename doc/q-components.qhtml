/* ========================================================= */
/* SHARED STYLE OBJECTS                                      */
/* ========================================================= */

q-style qbReset {
  box-sizing: border-box
}

q-style qbSurface {
  background: #ffffff
  color: #0f172a
  border: 1px solid #e2e8f0
  box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08)
}

q-style qbSoftSurface {
  background: #f8fafc
  color: #0f172a
  border: 1px solid #e2e8f0
}

q-style qbDarkSurface {
  background: #0f172a
  color: #ffffff
  border: 1px solid rgba(255, 255, 255, 0.10)
  box-shadow: 0 18px 45px rgba(15, 23, 42, 0.22)
}

q-style qbTitle {
  color: inherit
  font-size: 22px
  font-weight: 900
  letter-spacing: -0.04em
  line-height: 1.1
  margin: 0
}

q-style qbSmallTitle {
  color: inherit
  font-size: 16px
  font-weight: 900
  letter-spacing: -0.03em
  line-height: 1.2
  margin: 0
}

q-style qbBody {
  margin: 0
  font-size: 14px
  line-height: 1.6
  color: #64748b
}

q-style qbMutedText {
  color: #64748b
  line-height: 1.6
}

q-style qbLightText {
  color: #cbd5e1
  line-height: 1.6
}

q-style qbStack {
  display: grid
  gap: 12px
}

q-style qbInline {
  display: flex
  align-items: center
  gap: 10px
  flex-wrap: wrap
}


/* ========================================================= */
/* BUTTON STYLES                                             */
/* ========================================================= */

q-style qbButtonHost {
  display: inline-flex
  align-items: center
  justify-content: center
  width: fit-content
  min-height: 42px
  padding: 0 17px
  border-radius: 999px
  background: #2563eb
  color: #ffffff
  border: 1px solid #2563eb
  font-size: 14px
  font-weight: 850
  line-height: 1
  text-decoration: none
  cursor: pointer
  user-select: none
  white-space: nowrap
  box-shadow: 0 12px 28px rgba(37, 99, 235, 0.24)
}

q-style qbButtonSoft {
  background: #eff6ff
  color: #1d4ed8
  border: 1px solid #bfdbfe
  box-shadow: none
}

q-style qbButtonDark {
  background: #0f172a
  color: #ffffff
  border: 1px solid #1e293b
  box-shadow: 0 12px 28px rgba(15, 23, 42, 0.24)
}

q-style qbButtonGhost {
  background: transparent
  color: #0f172a
  border: 1px solid #e2e8f0
  box-shadow: none
}

q-style qbButtonWide {
  width: 100%
}


/* ========================================================= */
/* CARD STYLES                                               */
/* ========================================================= */

q-style qbCardHost {
  display: grid
  gap: 14px
  width: 100%
  min-width: 0
  border-radius: 22px
  padding: 22px
  overflow: hidden
}

q-style qbCardHeader {
  display: grid
  gap: 6px
}

q-style qbCardContent {
  display: grid
  gap: 12px
}

q-style qbCardFooter {
  display: flex
  align-items: center
  gap: 10px
  flex-wrap: wrap
  margin-top: 4px
}


/* ========================================================= */
/* NAVBAR STYLES                                             */
/* ========================================================= */

q-style qbNavbarHost {
  display: flex
  align-items: center
  justify-content: space-between
  gap: 18px
  width: 100%
  min-width: 0
  border-radius: 20px
  padding: 14px 18px
}

q-style qbNavbarBrand {
  display: flex
  align-items: center
  gap: 10px
  min-width: 0
  font-size: 20px
  font-weight: 950
  letter-spacing: -0.045em
  white-space: nowrap
}

q-style qbNavbarLinks {
  display: flex
  align-items: center
  justify-content: center
  gap: 18px
  flex-wrap: wrap
  min-width: 0
}

q-style qbNavbarLink {
  color: #64748b
  font-size: 14px
  font-weight: 780
  text-decoration: none
  cursor: pointer
}

q-style qbNavbarActions {
  display: flex
  align-items: center
  justify-content: flex-end
  gap: 10px
  flex-wrap: wrap
}


/* ========================================================= */
/* SIDEBAR STYLES                                            */
/* ========================================================= */

q-style qbSidebarHost {
  display: grid
  align-content: start
  gap: 16px
  width: 100%
  min-width: 0
  min-height: 100%
  border-radius: 22px
  padding: 18px
}

q-style qbSidebarHeader {
  display: grid
  gap: 5px
}

q-style qbSidebarNav {
  display: grid
  gap: 8px
}

q-style qbSidebarItem {
  display: block
  padding: 11px 13px
  border-radius: 13px
  color: #64748b
  font-size: 14px
  font-weight: 800
  text-decoration: none
  cursor: pointer
}

q-style qbSidebarItemActive {
  background: #dbeafe
  color: #1d4ed8
}

q-style qbSidebarFooter {
  display: grid
  gap: 10px
  margin-top: auto
}


/* ========================================================= */
/* PRICEBOX STYLES                                           */
/* ========================================================= */

q-style qbPriceboxHost {
  display: grid
  gap: 18px
  width: 100%
  min-width: 0
  border-radius: 24px
  padding: 24px
  overflow: hidden
}

q-style qbPriceboxFeatured {
  border: 1px solid #2563eb
  box-shadow: 0 20px 56px rgba(37, 99, 235, 0.18)
}

q-style qbPriceboxTop {
  display: grid
  gap: 8px
}

q-style qbPrice {
  display: flex
  align-items: end
  gap: 6px
  color: inherit
  font-size: 46px
  font-weight: 950
  letter-spacing: -0.07em
  line-height: 1
  margin: 0
}

q-style qbPricePeriod {
  color: #64748b
  font-size: 14px
  font-weight: 750
  letter-spacing: 0
  line-height: 1.35
  padding-bottom: 5px
}

q-style qbFeatureList {
  display: grid
  gap: 10px
  margin: 0
  padding: 0
}

q-style qbFeatureItem {
  display: grid
  grid-template-columns: 18px 1fr
  gap: 10px
  align-items: start
  color: #64748b
  font-size: 14px
  line-height: 1.5
}

q-style qbCheck {
  width: 18px
  height: 18px
  border-radius: 999px
  background: #dcfce7
  color: #166534
  display: grid
  place-items: center
  font-size: 12px
  font-weight: 950
}


/* ========================================================= */
/* GROUPBOX STYLES                                           */
/* ========================================================= */

q-style qbGroupboxHost {
  position: relative
  display: grid
  gap: 14px
  width: 100%
  min-width: 0
  border-radius: 20px
  padding: 28px 20px 20px
  margin-top: 12px
  border: 1px solid #cbd5e1
  background: #ffffff
}

q-style qbGroupboxLabel {
  position: absolute
  top: -13px
  left: 18px
  display: inline-flex
  align-items: center
  min-height: 26px
  padding: 0 11px
  border-radius: 999px
  background: #ffffff
  border: 1px solid #cbd5e1
  color: #334155
  font-size: 13px
  font-weight: 900
  box-shadow: 0 8px 22px rgba(15, 23, 42, 0.08)
}

q-style qbGroupboxContent {
  display: grid
  gap: 12px
}


/* ========================================================= */
/* THEME MAP                                                 */
/* ========================================================= */

q-theme qbTheme {
  q-button { qbReset qbButtonHost }
  q-button.soft { qbButtonSoft }
  q-button.dark { qbButtonDark }
  q-button.ghost { qbButtonGhost }
  q-button.wide { qbButtonWide }

  q-card { qbReset qbSurface qbCardHost }
  q-card.soft { qbSoftSurface }
  q-card.dark { qbDarkSurface }
  q-card-header { qbCardHeader }
  q-card-content { qbCardContent }
  q-card-footer { qbCardFooter }

  q-navbar { qbReset qbSurface qbNavbarHost }
  q-navbar.dark { qbDarkSurface }
  q-navbar-brand { qbNavbarBrand }
  q-navbar-links { qbNavbarLinks }
  q-navbar-link { qbNavbarLink }
  q-navbar-actions { qbNavbarActions }

  q-sidebar { qbReset qbSurface qbSidebarHost }
  q-sidebar.dark { qbDarkSurface }
  q-sidebar-header { qbSidebarHeader }
  q-sidebar-nav { qbSidebarNav }
  q-sidebar-item { qbSidebarItem }
  q-sidebar-item.active { qbSidebarItem qbSidebarItemActive }
  q-sidebar-footer { qbSidebarFooter }

  q-pricebox { qbReset qbSurface qbPriceboxHost }
  q-pricebox.featured { qbPriceboxFeatured }
  q-pricebox.dark { qbDarkSurface }
  q-pricebox-top { qbPriceboxTop }
  q-price { qbPrice }
  q-price-period { qbPricePeriod }
  q-feature-list { qbFeatureList }
  q-feature-item { qbFeatureItem }
  q-check { qbCheck }

  q-groupbox { qbReset qbGroupboxHost }
  q-groupbox-label { qbGroupboxLabel }
  q-groupbox-content { qbGroupboxContent }

  h1.qb-title { qbTitle }
  h2.qb-title { qbTitle }
  h3.qb-title { qbTitle }
  h4.qb-title { qbSmallTitle }

  p.qb-body { qbBody }
  p.qb-muted { qbMutedText }
  p.qb-light { qbLightText }

  div.qb-stack { qbStack }
  div.qb-inline { qbInline }
}


/* ========================================================= */
/* COMPONENT: q-button                                       */
/* Slots: content                                             */
/* ========================================================= */

q-component q-button {
  q-var label { this.getAttribute("label") || "" }

  button {
    type: "button"

    slot { content }

    text { ${label} }
  }
}


/* ========================================================= */
/* COMPONENT: q-card                                         */
/* Slots: header, content, footer                             */
/* ========================================================= */

q-component q-card {
  q-var title { this.getAttribute("title") || "" }
  q-var subtitle { this.getAttribute("subtitle") || "" }

  q-card-header {
    slot { header }

    h3.qb-title {
      text { ${title} }
    }

    p.qb-muted {
      text { ${subtitle} }
    }
  }

  q-card-content {
    slot { content }
  }

  q-card-footer {
    slot { footer }
  }
}


/* ========================================================= */
/* COMPONENT: q-navbar                                       */
/* Slots: brand, links, actions                               */
/* ========================================================= */

q-component q-navbar {
  q-var brand { this.getAttribute("brand") || "Brand" }

  q-var links {
    [
      { label: "Overview" },
      { label: "Features" },
      { label: "Docs" },
      { label: "Contact" }
    ]
  }

  q-navbar-brand {
    slot { brand }

    text { ${brand} }
  }

  q-navbar-links {
    slot { links }

    for (item in links) {
      q-navbar-link {
        text { ${item.label} }
      }
    }
  }

  q-navbar-actions {
    slot { actions }
  }
}


/* ========================================================= */
/* COMPONENT: q-sidebar                                      */
/* Slots: header, nav, footer                                 */
/* ========================================================= */

q-component q-sidebar {
  q-var title { this.getAttribute("title") || "Navigation" }
  q-var subtitle { this.getAttribute("subtitle") || "" }

  q-var items {
    [
      { label: "General Information", active: true },
      { label: "Features" },
      { label: "Documentation" },
      { label: "Guides" },
      { label: "Best Practices" },
      { label: "Comparisons" }
    ]
  }

  q-sidebar-header {
    slot { header }

    h3.qb-title {
      text { ${title} }
    }

    p.qb-muted {
      text { ${subtitle} }
    }
  }

  q-sidebar-nav {
    slot { nav }

    for (item in items) {
      q-sidebar-item {
        q-var cls { item.active ? "active" : "" }

        class: "${cls}"

        text { ${item.label} }
      }
    }
  }

  q-sidebar-footer {
    slot { footer }
  }
}


/* ========================================================= */
/* COMPONENT: q-pricebox                                     */
/* Slots: top, price, features, actions                       */
/* ========================================================= */

q-component q-pricebox {
  q-var plan { this.getAttribute("plan") || "Pro" }
  q-var price { this.getAttribute("price") || "$49" }
  q-var period { this.getAttribute("period") || "/ month" }
  q-var description { this.getAttribute("description") || "For professional teams that need a clean, scalable plan." }
  q-var cta { this.getAttribute("cta") || "Choose Plan" }

  q-var features {
    [
      "Unlimited projects",
      "Priority support",
      "Advanced dashboard",
      "Team access"
    ]
  }

  q-pricebox-top {
    slot { top }

    h3.qb-title {
      text { ${plan} }
    }

    p.qb-muted {
      text { ${description} }
    }
  }

  q-price {
    slot { price }

    text { ${price} }

    q-price-period {
      text { ${period} }
    }
  }

  q-feature-list {
    slot { features }

    for (feature in features) {
      q-feature-item {
        q-check {
          text { ✓ }
        }

        span {
          text { ${feature} }
        }
      }
    }
  }

  q-card-footer {
    slot { actions }

    q-button.wide {
      label: "${cta}"
    }
  }
}


/* ========================================================= */
/* COMPONENT: q-groupbox                                     */
/* Slots: label, content                                      */
/* ========================================================= */

q-component q-groupbox {
  q-var label { this.getAttribute("label") || "Group" }

  q-groupbox-label {
    slot { label }

    text { ${label} }
  }

  q-groupbox-content {
    slot { content }
  }
}


/* ========================================================= */
/* LIGHTWEIGHT SEMANTIC CHILD COMPONENTS                      */
/* ========================================================= */

q-component q-card-header {
  slot { content }
}

q-component q-card-content {
  slot { content }
}

q-component q-card-footer {
  slot { content }
}

q-component q-navbar-brand {
  slot { content }
}

q-component q-navbar-links {
  slot { content }
}

q-component q-navbar-link {
  slot { content }
}

q-component q-navbar-actions {
  slot { content }
}

q-component q-sidebar-header {
  slot { content }
}

q-component q-sidebar-nav {
  slot { content }
}

q-component q-sidebar-item {
  slot { content }
}

q-component q-sidebar-footer {
  slot { content }
}

q-component q-pricebox-top {
  slot { content }
}

q-component q-price {
  slot { content }
}

q-component q-price-period {
  slot { content }
}

q-component q-feature-list {
  slot { content }
}

q-component q-feature-item {
  slot { content }
}

q-component q-check {
  slot { content }
}

q-component q-groupbox-label {
  slot { content }
}

q-component q-groupbox-content {
  slot { content }
}

q-component q-dom-tree extends q-tree-view {
  q-property filters: q-array { "q-property", "q-signal", "slot" }
  q-property includeFullTree: true

  function _effectiveModel() {
    if (this.__qdomTreeRawModel && typeof this.__qdomTreeRawModel === "object") {
      return this.__qdomTreeRawModel
    }
    if (this.__treeRawModel && typeof this.__treeRawModel === "object") {
      return this.__treeRawModel
    }
    var value = this.treeModel
    if (value === null || typeof value === "undefined" || value === "") { value = this.model }
    if (value === null || typeof value === "undefined" || value === "") { value = this.getAttribute("treeModel") }
    if (value === null || typeof value === "undefined" || value === "") { value = this.getAttribute("model") }
    return value
  }

  function _setRawModel(value) {
    var normalized = value && typeof value === "object" ? value : {}
    this.__qdomTreeRawModel = normalized
    this.treeModel = ""
    this.model = ""
    return normalized
  }

  function _normalizeFilters(input) {
    if (Array.isArray(input)) {
      var out = []
      var i = 0
      while (i < input.length) {
        var token = String(input[i] || "").trim().toLowerCase()
        if (token && out.indexOf(token) < 0) {
          out.push(token)
        }
        i += 1
      }
      return out
    }
    if (typeof input === "string") {
      return this._normalizeFilters(String(input || "").split(/[\s,]+/g))
    }
    return this._normalizeFilters(this.filters)
  }

  function _resolveIncludeFullTree(options) {
    if (options && typeof options === "object" && Object.prototype.hasOwnProperty.call(options, "includeFullTree")) {
      return options.includeFullTree === true
    }
    return this.includeFullTree === true
  }

  function load(source, options) {
    if (source && typeof source === "object" && typeof source.qmap === "function") {
      return this.loadFromQDom(source, options)
    }
    if (source && source.nodeType === 1) {
      return this.loadFromElement(source, options)
    }
    if (source && typeof source === "object" && typeof source.kind === "string") {
      return this.loadFromQDom(source, options)
    }
    if (typeof source === "string") {
      var selector = String(source || "").trim()
      if (selector) {
        var element = document.querySelector(selector)
        if (element) {
          return this.loadFromElement(element, options)
        }
      }
      return this.loadFromObject({}, options)
    }
    if (Array.isArray(source)) {
      return this.loadFromArray(source, options)
    }
    if (source && typeof source === "object") {
      return this.loadFromObject(source, options)
    }
    return this.loadFromObject({}, options)
  }

  function loadFromQDom(qdomNode, options) {
    var filters = this._normalizeFilters(options && options.filters)
    var includeFullTree = this._resolveIncludeFullTree(options)
    var mapped = {}
    if (qdomNode && typeof qdomNode.qmap === "function") {
      mapped = qdomNode.qmap(filters, includeFullTree)
    } else if (globalThis.QHtml && typeof globalThis.QHtml.qmapNode === "function") {
      mapped = globalThis.QHtml.qmapNode(qdomNode, {
        filters: filters,
        includeFullTree: includeFullTree
      })
    }
    this._setRawModel(mapped)
    this.refresh()
    return mapped
  }

  function loadFromElement(element, options) {
    if (!element || typeof element.qdom !== "function") {
      return this.loadFromObject({}, options)
    }
    return this.loadFromQDom(element.qdom(), options)
  }

  function loadFromObject(value) {
    var out = this._setRawModel(value)
    this.refresh()
    return out
  }

  function loadFromArray(value) {
    var out = this._setRawModel(Array.isArray(value) ? value : [])
    this.refresh()
    return out
  }

  function import(value, options) {
    return this.load(value, options)
  }

  function export() {
    return this.__qdomTreeRawModel && typeof this.__qdomTreeRawModel === "object"
      ? this.__qdomTreeRawModel
      : {}
  }
}

q-component q-draggable-item {
  q-property { x y }

  function numberOr(value, fallback) {
    var n = Number(value);
    if (!Number.isFinite(n)) {
      return Number(fallback);
    }
    return n;
  }

  function applyPosition(rawX, rawY) {
    var nextX = Math.round(this.numberOr(rawX, this.x == null ? 40 : this.x));
    var nextY = Math.round(this.numberOr(rawY, this.y == null ? 40 : this.y));

    this.x = nextX;
    this.y = nextY;

    if (this.style) {
      this.style.position = "fixed";
      this.style.left = String(nextX) + "px";
      this.style.top = String(nextY) + "px";
      if (!this.style.zIndex) {
        this.style.zIndex = "1000";
      }
    }

    return { x: nextX, y: nextY };
  }

  function dragHandle() {
    return this.querySelector("[q-drag-handle='1']") || this;
  }

  function handleDragStart(event) {
    if (!event || (event.button != null && event.button !== 0)) {
      return;
    }

    var start = this.getBoundingClientRect ? this.getBoundingClientRect() : { left: 0, top: 0 };
    this.__dragState = {
      mouseX: Number(event.clientX || 0),
      mouseY: Number(event.clientY || 0),
      startLeft: Number(start.left || 0),
      startTop: Number(start.top || 0)
    };

    var win = this.ownerDocument && this.ownerDocument.defaultView ? this.ownerDocument.defaultView : window;
    if (!this.__dragMoveHandler) {
      var host = this;
      this.__dragMoveHandler = function(moveEvent) {
        if (!host.__dragState) {
          return;
        }
        var dx = Number(moveEvent.clientX || 0) - host.__dragState.mouseX;
        var dy = Number(moveEvent.clientY || 0) - host.__dragState.mouseY;
        host.applyPosition(host.__dragState.startLeft + dx, host.__dragState.startTop + dy);
      };
    }

    if (!this.__dragEndHandler) {
      var hostEnd = this;
      this.__dragEndHandler = function() {
        hostEnd.__dragState = null;
        win.removeEventListener("mousemove", hostEnd.__dragMoveHandler);
        win.removeEventListener("mouseup", hostEnd.__dragEndHandler);
      };
    }

    win.addEventListener("mousemove", this.__dragMoveHandler);
    win.addEventListener("mouseup", this.__dragEndHandler);

    if (typeof event.preventDefault === "function") {
      event.preventDefault();
    }
  }

  function setupDragging() {
    if (this.__dragReady) {
      return;
    }
    this.__dragReady = true;

    var handle = this.dragHandle();
    if (!handle || typeof handle.addEventListener !== "function") {
      return;
    }

    var host = this;
    this.__dragStartHandler = function(event) {
      host.handleDragStart(event);
    };

    handle.addEventListener("mousedown", this.__dragStartHandler);
  }

  onReady {
    this.setupDragging();
    this.applyPosition(this.x, this.y);
  }
}

q-component estore-cart {
  q-property cartData: q-array { }
  function addItem(name, price) { this.component.cartData.push(QMap({"name": name, "price": price }));
    console.log(JSON.stringify(this.component.cartData))
  }
  function removeItem(name, price) { }
  slot { cartModal }
}

q-component estore-catalog {
  q-signal addItem(name, price)
  q-property productData: q-array {
    q-map {
      SKU: "NL-100"
      name: "Night Lamp"
      description: "Warm bedside glow"
      price: "39.99"
    },
    q-map {
      SKU: "DC-220"
      name: "Desk Clock"
      description: "Minimal analog clock"
      price: "24.50"
    },
    q-map {
      SKU: "MK-305"
      name: "Ceramic Mug"
      description: "Matte finish coffee mug"
      price: "14.00"
    },
    q-map {
      SKU: "NB-410"
      name: "Notebook Set"
      description: "Hardcover dotted journals"
      price: "19.95"
    }
  }

  q-grid {
    columns: 3
    for (product in this.component.productData) {
      div.w3-panel.w3-border.w3-round-large {
        style { minHeight: 170px; padding: 0.8rem; display: flex; flex-direction: column; justify-content: space-between; background: #fff; }
        div.w3-small.w3-text-gray { text { SKU: ${product.SKU} } }
        div.estore-name-row,span.estore-name-text { text { ${product.name} } }
        div.estore-description-row,span.estore-description-text { text { ${product.description} } }
        div.estore-price-row,span.estore-price-text.w3-text-indigo { text { $${product.price} } }
        div.estore-action-row {
          button {
            text { add to cart }
            onclick { this.component.addItem("${product.name}", "${product.price}") }
          }
        }
      }
    }
  }
}

q-component q-estore {
  estore-cart mycart {
    q-modal cartmodal {
      onready { this.component.hide() }
      title { text { Shopping Cart } }
      content {
        ul {
          for (product in mycart.cartData) {
            li { text { ${product.name} - ${product.price} } }
          }
        }
      }
    }
  }

  button {
    text { checkout }
    onclick { this.component.mycart.cartmodal.show() }
  }

  estore-catalog mycatalog { }
  q-connect { mycatalog.addItem mycart.addItem }
}

q-component q-factory {
  q-property target: ""
  q-property lastUuid: ""
  q-property count: 0

  q-signal created(uuid)

  function getRootHost() {
    if (this.qhtml && this.qhtml.nodeType === 1) {
      return this.qhtml;
    }
    if (this.closest) {
      return this.closest("q-html");
    }
    return null;
  }

  function getRootQDom() {
    var host = this.getRootHost();
    return host && typeof host.qdom === "function" ? host.qdom() : null;
  }

  function getTemplateSlot() {
    var self = typeof this.qdom === "function" ? this.qdom() : null;
    return self && typeof self.slot === "function" ? self.slot("default") : null;
  }

  function templateQHTML() {
    var slot = this.getTemplateSlot();
    if (!slot) {
      return "";
    }
    if (typeof slot.listChildren === "function") {
      var children = slot.listChildren();
      if (children && typeof children.qhtml === "function") {
        return String(children.qhtml({ preserveOriginal: false }) || "").trim();
      }
    }
    if (slot.children && typeof slot.children.qhtml === "function") {
      return String(slot.children.qhtml({ preserveOriginal: false }) || "").trim();
    }
    if (typeof slot.qhtml === "function") {
      return String(slot.qhtml({ preserveOriginal: false }) || "").trim();
    }
    return "";
  }

  function resolveTargetQDom(root, targetOverride) {
    var rootQdom = root || this.getRootQDom();
    if (!rootQdom) {
      return null;
    }
    if (targetOverride && typeof targetOverride === "object") {
      if (typeof targetOverride.appendToSlot === "function") {
        return targetOverride;
      }
      if (typeof targetOverride.qdom === "function") {
        return targetOverride.qdom();
      }
      if (typeof targetOverride.appendNode === "function") {
        return targetOverride;
      }
    }
    var targetValue = typeof targetOverride === "string" && targetOverride.trim()
      ? targetOverride
      : String(this.target || "").trim();
    if (!targetValue) {
      return rootQdom;
    }
    if (typeof rootQdom.find === "function") {
      var found = rootQdom.find(targetValue);
      if (found && typeof found.appendNode === "function") {
        return found;
      }
    }
    return rootQdom;
  }

  function normalizeCreatedNode(created) {
    if (!created) {
      return null;
    }
    if (Array.isArray(created)) {
      return created.length > 0 ? created[0] : null;
    }
    if (created.toArray && typeof created.toArray === "function") {
      var arr = created.toArray();
      return arr && arr.length > 0 ? arr[0] : null;
    }
    return created;
  }

  function normalizeProps(value) {
    if (!value) {
      return {};
    }
    if (typeof value.toObject === "function") {
      return value.toObject() || {};
    }
    if (typeof value.toMap === "function") {
      return value.toMap() || {};
    }
    if (typeof value === "object") {
      return value;
    }
    return {};
  }

  function applyPropsToQDomNode(node, props) {
    if (!node || typeof node !== "object") {
      return node;
    }
    if (Array.isArray(node)) {
      for (var ai = 0; ai < node.length; ai += 1) {
        this.applyPropsToQDomNode(node[ai], props);
      }
      return node;
    }
    var incoming = this.normalizeProps(props);
    var keys = Object.keys(incoming);
    if (keys.length === 0) {
      return node;
    }
    if (!node.props || typeof node.props !== "object" || Array.isArray(node.props)) {
      node.props = {};
    }
    if (!node.attributes || typeof node.attributes !== "object" || Array.isArray(node.attributes)) {
      node.attributes = {};
    }
    for (var i = 0; i < keys.length; i += 1) {
      var key = String(keys[i] || "").trim();
      if (!key) {
        continue;
      }
      var value = incoming[keys[i]];
      node.props[key] = value;
      node.attributes[key] = String(value);
    }
    return node;
  }

  function applyPropsToElement(element, props) {
    if (!element || typeof element !== "object") {
      return element;
    }
    var incoming = this.normalizeProps(props);
    var keys = Object.keys(incoming);
    for (var i = 0; i < keys.length; i += 1) {
      var key = String(keys[i] || "").trim();
      if (!key) {
        continue;
      }
      var value = incoming[keys[i]];
      try {
        element[key] = value;
      } catch (ignoredPropertyWrite) { }
      if (element.setAttribute) {
        element.setAttribute(key, String(value));
      }
    }
    return element;
  }

  function sanitizeQDomNode(node) {
    if (!node || typeof node !== "object") {
      return node;
    }
    if (Array.isArray(node)) {
      for (var ai = 0; ai < node.length; ai += 1) {
        this.sanitizeQDomNode(node[ai]);
      }
      return node;
    }
    if (Object.prototype.hasOwnProperty.call(node, "component")) {
      try { delete node.component; } catch (ignoredDeleteComponent) { node.component = null; }
    }
    var lists = [node.nodes, node.children, node.templateNodes, node.slots, node.__qhtmlSlotNodes];
    if (node.model && typeof node.model === "object") {
      this.sanitizeQDomNode(node.model);
    }
    if (Array.isArray(node.entries)) {
      for (var ei = 0; ei < node.entries.length; ei += 1) {
        var entry = node.entries[ei];
        if (entry && typeof entry === "object" && Array.isArray(entry.nodes)) {
          this.sanitizeQDomNode(entry.nodes);
        }
      }
    }
    for (var li = 0; li < lists.length; li += 1) {
      if (Array.isArray(lists[li])) {
        this.sanitizeQDomNode(lists[li]);
      }
    }
    return node;
  }

  function coerceFactoryNode(root, node) {
    if (!node || typeof node !== "object") {
      return node;
    }
    if (Array.isArray(node)) {
      var out = [];
      for (var i = 0; i < node.length; i += 1) {
        out.push(this.coerceFactoryNode(root, node[i]));
      }
      return out;
    }
    var kind = String(node.kind || "").trim().toLowerCase();
    var tagName = String(node.tagName || node.componentId || "").trim().toLowerCase();
    if (
      kind === "element" &&
      tagName.indexOf("-") !== -1 &&
      root &&
      typeof root.createQComponentInstance === "function"
    ) {
      var attrs = node.attributes && typeof node.attributes === "object" ? Object.assign({}, node.attributes) : {};
      return root.createQComponentInstance({
        componentId: tagName,
        tagName: tagName,
        attributes: attrs,
        props: Object.assign({}, attrs),
        children: Array.isArray(node.children) ? node.children : []
      });
    }
    return node;
  }

  function resolveCreatedElement(scope, qdomNode) {
    if (!scope || !qdomNode) {
      return null;
    }
    var uuid = String(qdomNode.UUID || (qdomNode.meta && qdomNode.meta.uuid) || "").trim();
    if (!uuid) {
      return null;
    }
    if (typeof scope.elementForUuid === "function") {
      var byUuid = scope.elementForUuid(uuid);
      if (byUuid) {
        return byUuid;
      }
    }
    if (scope.querySelectorAll) {
      var all = scope.querySelectorAll("[qdom-uuid='" + uuid + "'],[data-qdom-uuid='" + uuid + "']");
      if (all && all.length > 0) {
        return all[0];
      }
    }
    var tagName = String(qdomNode.tagName || qdomNode.componentId || "").trim();
    if (tagName && scope.querySelectorAll) {
      var matches = scope.querySelectorAll(tagName);
      if (matches && matches.length > 0) {
        return matches[matches.length - 1];
      }
    }
    return null;
  }

  function refreshTarget(scope, target, createdNode) {
    if (!scope || !target) {
      return false;
    }
    var targetQdom = target
    var targetUuid = String((targetQdom && targetQdom.UUID) || "").trim();
    var createdUuid = String(createdNode && (createdNode.UUID || (createdNode.meta && createdNode.meta.uuid)) || "").trim();
    var updateUuid = targetUuid || createdUuid;
    if (!updateUuid || typeof scope.update !== "function") {
      return false;
    }
    return scope.update(updateUuid);
  }

  function create(options) {
    var opts = options && typeof options === "object" ? options : {};
    var scope = this.getRootHost();
    var root = scope && typeof scope.qdom === "function" ? scope.qdom() : null;
    if (!scope || !root || typeof root.createInstanceFromQHTML !== "function") {
      return null;
    }

    var source = String(opts.source || this.templateQHTML() || "").trim();
    if (!source) {
      return null;
    }
    var factoryQdom = typeof this.qdom === "function" ? this.qdom() : null;
    this.sanitizeQDomNode(factoryQdom);
    this.sanitizeQDomNode(root);

    var target = this.resolveTargetQDom(root, opts.target || "");
    if (!target || (typeof target.appendNode !== "function" && typeof target.appendToSlot !== "function")) {
      return null;
    }

    var created = root.createInstanceFromQHTML(source);
    created = this.coerceFactoryNode(root, created);
    this.applyPropsToQDomNode(created, opts.props || opts.properties || {});
    this.sanitizeQDomNode(created);
    var appended = typeof target.appendToSlot === "function"
      ? target.appendToSlot("default", created)
      : target.appendNode(created);
    var createdNode = this.normalizeCreatedNode(appended) || this.normalizeCreatedNode(created);
    if (!createdNode) {
      return null;
    }

    this.refreshTarget(scope, target, createdNode);

    var uuid = String(createdNode.UUID || (createdNode.meta && createdNode.meta.uuid) || "").trim();
    this.lastUuid = uuid;
    this.count = Number(this.count || 0) + 1;

    var instance = this.resolveCreatedElement(scope, createdNode);
    this.applyPropsToElement(instance, opts.props || opts.properties || {});
    if (typeof this.created === "function") {
      this.created(uuid);
    }
    return instance || createdNode;
  }

  onReady {
    this.style.display = "none";
  }
}

q-style q-form-root-style {
  q-style-class { w3-container w3-margin-top w3-margin-bottom }
  color: #102a43
}

q-style q-form-shell-style {
  q-style-class { w3-card w3-round-large w3-padding }
  backgroundColor: #eef4fb
  color: #102a43
  border: 1px solid #c7d8ef
}

q-style q-form-input-style {
  q-style-class { w3-input w3-border w3-round-large w3-margin-bottom }
  backgroundColor: #f8fbff
  color: #102a43
  borderColor: #c7d8ef
}

q-style q-form-textarea-style {
  q-style-class { w3-input w3-border w3-round-large w3-margin-bottom }
  backgroundColor: #f8fbff
  color: #102a43
  borderColor: #c7d8ef
}

q-style q-form-submit-style {
  q-style-class { w3-button w3-round-large w3-margin-top }
  backgroundColor: #334155
  color: #f8fbff
  border: 1px solid #1e293b
}

q-default-theme q-form-theme {
  .q-form-root { q-form-root-style }
  .q-form-shell { q-form-shell-style }
  .q-form-input { q-form-input-style }
  .q-form-textarea { q-form-textarea-style }
  .q-form-submit { q-form-submit-style }
}

q-keyword q-form { q-form-theme,form.q-form-root,div.q-form-shell }
q-keyword q-input { q-form-theme,input.q-form-input }
q-keyword q-textarea { q-form-theme,textarea.q-form-textarea }
q-keyword q-submit { q-form-theme,button.q-form-submit }

q-rewrite q-grid {
  slot { main }
  return {
    q-script {
      var src = this.slot("main");
      var match = src.match(/\bcolumns\s*:\s*(\d+)\s*;?/i);
      var cols = match ? Math.max(1, parseInt(match[1], 10)) : 1;
      var body = src.replace(/\bcolumns\s*:\s*\d+\s*;?/i, "").trim();

      return "div {" +
        " class: \"q-grid-rewrite\"" +
        " style { display: grid; grid-template-columns: repeat(" + cols + ", minmax(0, 1fr)); gap: 12px; align-items: stretch; } " +
        body +
      " }";
    }
  }
}

q-painter hudButtonPainter {
  q-property hudHover: "0"
  q-property hudActive: "0"
  q-property hudLine: "0"
  q-property hudAccent: "#6ea8ff"
  q-property hudWarn: "#ff7a18"
  q-property hudYellow: "#f8e66b"

  onpaint {
    const n = (v, d) => {
      const x = parseFloat(String(v ?? d));
      return Number.isFinite(x) ? x : d;
    };

    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
    const read = (camel, css, fallback) => this[camel] ?? this[css] ?? fallback;

    const w = this.width;
    const h = this.height;

    const hover = clamp(n(read("hudHover", "--hud-hover", 0), 0), 0, 1);
    const active = clamp(n(read("hudActive", "--hud-active", 0), 0), 0, 1);
    const line = clamp(n(read("hudLine", "--hud-line", 0), 0), 0, 1);

    const accent = String(read("hudAccent", "--hud-accent", "#6ea8ff"));
    const warn = String(read("hudWarn", "--hud-warn", "#ff7a18"));
    const yellow = String(read("hudYellow", "--hud-yellow", "#f8e66b"));

    const cut = 16;
    const notch = 34;

    this.save();
    this.clearRect(0, 0, w, h);

    this.beginPath();
    this.moveTo(cut, 0);
    this.lineTo(w - notch, 0);
    this.lineTo(w, h * 0.5);
    this.lineTo(w - notch, h);
    this.lineTo(cut, h);
    this.lineTo(0, h - cut);
    this.lineTo(0, cut);
    this.closePath();

    let bg = this.createLinearGradient(0, 0, w, h);
    bg.addColorStop(0, "#10264a");
    bg.addColorStop(0.5, "#0b1528");
    bg.addColorStop(1, "#050912");

    this.fillStyle = bg;
    this.fill();

    this.globalAlpha = 0.18 + hover * 0.2 + active * 0.24;
    this.fillStyle = accent;
    this.fill();

    this.globalAlpha = 1;
    this.strokeStyle = accent;
    this.lineWidth = 1.5;
    this.stroke();

    this.strokeStyle = yellow;
    this.lineWidth = 2;
    this.beginPath();
    this.moveTo(w - 24, 7);
    this.lineTo(w - 6, 7);
    this.stroke();

    this.strokeStyle = warn;
    this.beginPath();
    this.moveTo(w - 18, 4);
    this.lineTo(w - 2, 4);
    this.stroke();

    this.globalAlpha = 0.85;
    this.strokeStyle = accent;
    this.lineWidth = 2;
    this.beginPath();
    this.moveTo(cut + 10, 10);
    this.lineTo(cut + 10 + (w - notch - cut - 30) * line, 10);
    this.stroke();

    this.globalAlpha = 0.55;
    this.strokeStyle = "#ffffff";
    this.lineWidth = 1;
    this.beginPath();
    this.moveTo(cut + 4, 4);
    this.lineTo(w - notch - 10, 4);
    this.stroke();

    this.globalAlpha = active ? 0.95 : 0.36 + hover * 0.36;
    this.strokeStyle = active ? warn : accent;
    this.lineWidth = 2;
    this.beginPath();
    this.moveTo(w - notch + 6, h * 0.5);
    this.lineTo(w - 8, h * 0.5);
    this.stroke();

    this.globalAlpha = 1;
    this.restore();
  }
}

q-painter hudSpinePainter {
  q-property hudActive: "0"
  q-property hudAccent: "#6ee7ff"
  q-property hudWarn: "#ff7a18"

  onpaint {
    const n = (v, d) => {
      const x = parseFloat(String(v ?? d));
      return Number.isFinite(x) ? x : d;
    };

    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
    const read = (camel, css, fallback) => this[camel] ?? this[css] ?? fallback;

    const w = this.width;
    const h = this.height;

    const active = clamp(n(read("hudActive", "--hud-active", 0), 0), 0, 1);
    const accent = String(read("hudAccent", "--hud-accent", "#6ee7ff"));
    const warn = String(read("hudWarn", "--hud-warn", "#ff7a18"));

    this.save();
    this.clearRect(0, 0, w, h);

    let bg = this.createLinearGradient(0, 0, w, 0);
    bg.addColorStop(0, "#111827");
    bg.addColorStop(0.5, "#1f2937");
    bg.addColorStop(1, "#070b13");

    this.fillStyle = bg;
    this.fillRect(0, 0, w, h);

    this.globalAlpha = 0.35;
    this.strokeStyle = accent;
    this.lineWidth = 1;

    for (let i = 0; i < 12; i++) {
      const y = 28 + i * 42;

      this.beginPath();
      this.moveTo(8, y);
      this.lineTo(24, y + 16);
      this.lineTo(24, y + 34);
      this.stroke();
    }

    this.globalAlpha = 0.8;
    this.strokeStyle = active > 0.5 ? warn : accent;
    this.lineWidth = 2;

    this.beginPath();
    this.moveTo(w - 12, 20);
    this.lineTo(w - 12, h - 20);
    this.stroke();

    for (let i = 0; i < 8; i++) {
      const y = h * 0.22 + i * 34;

      this.fillStyle = i % 2 ? warn : accent;
      this.globalAlpha = 0.45 + active * 0.35;
      this.fillRect(w - 17, y, 9, 3);
    }

    this.globalAlpha = 0.45;
    this.fillStyle = "#ffffff";
    this.fillRect(w - 2, 0, 1, h);

    this.globalAlpha = 0.28 + active * 0.28;
    this.fillStyle = accent;
    this.fillRect(0, 0, 2, h);

    this.restore();
  }
}

q-painter hudMetalPanelPainter {
  q-property hudDent: "1"
  q-property hudPanel: "1"
  q-property hudGrime: "1"
  q-property hudRivets: "1"
  q-property hudAccent: "#6ee7ff"

  onpaint {
    const n = (v, d) => {
      const x = parseFloat(String(v ?? d));
      return Number.isFinite(x) ? x : d;
    };

    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));

    const read = (camel, css, fallback) => {
      return this[camel] ?? this[css] ?? fallback;
    };

    const rand = seed => {
      let x = Math.sin(seed * 999.137) * 43758.5453123;
      return x - Math.floor(x);
    };

    const w = this.width;
    const h = this.height;

    const dent = clamp(n(read("hudDent", "--hud-dent", 1), 1), 0, 1);
    const panel = clamp(n(read("hudPanel", "--hud-panel", 1), 1), 0, 1);
    const grime = clamp(n(read("hudGrime", "--hud-grime", 1), 1), 0, 1);
    const rivets = clamp(n(read("hudRivets", "--hud-rivets", 1), 1), 0, 1);
    const accent = String(read("hudAccent", "--hud-accent", "#6ee7ff"));

    const corner = 28 * dent;
    const leftBite = 72 * dent;
    const border = 16;

    const x0 = 0;
    const y0 = 0;
    const x1 = w;
    const y1 = h;

    const drawOuterShape = () => {
      this.beginPath();
      this.moveTo(x0 + corner, y0);
      this.lineTo(x1 - corner, y0);
      this.quadraticCurveTo(x1, y0, x1, y0 + corner);
      this.lineTo(x1, y1 - corner);
      this.quadraticCurveTo(x1, y1, x1 - corner, y1);
      this.lineTo(x0 + leftBite, y1);
      this.lineTo(x0 + leftBite, y1 - 44);
      this.lineTo(x0, y1 - 92);
      this.lineTo(x0, y0 + corner);
      this.quadraticCurveTo(x0, y0, x0 + corner, y0);
      this.closePath();
    };

    const drawInnerShape = () => {
      const b = border;
      this.beginPath();
      this.moveTo(x0 + corner + b, y0 + b);
      this.lineTo(x1 - corner - b, y0 + b);
      this.quadraticCurveTo(x1 - b, y0 + b, x1 - b, y0 + corner + b);
      this.lineTo(x1 - b, y1 - corner - b);
      this.quadraticCurveTo(x1 - b, y1 - b, x1 - corner - b, y1 - b);
      this.lineTo(x0 + leftBite + b, y1 - b);
      this.lineTo(x0 + leftBite + b, y1 - 52);
      this.lineTo(x0 + b, y1 - 100);
      this.lineTo(x0 + b, y0 + corner + b);
      this.quadraticCurveTo(x0 + b, y0 + b, x0 + corner + b, y0 + b);
      this.closePath();
    };

    this.save();
    this.clearRect(0, 0, w, h);

    drawOuterShape();

    let outer = this.createLinearGradient(0, 0, w, h);
    outer.addColorStop(0, "#b9b0a3");
    outer.addColorStop(0.08, "#2e2b29");
    outer.addColorStop(0.5, "#100f0f");
    outer.addColorStop(0.92, "#4b4844");
    outer.addColorStop(1, "#d6d0c3");

    this.fillStyle = outer;
    this.fill();

    drawInnerShape();

    let metal = this.createLinearGradient(0, 0, w, h);
    metal.addColorStop(0, "#6d675f");
    metal.addColorStop(0.22, "#393733");
    metal.addColorStop(0.5, "#272623");
    metal.addColorStop(0.78, "#46413b");
    metal.addColorStop(1, "#1a1918");

    this.fillStyle = metal;
    this.fill();

    this.save();
    drawInnerShape();
    this.clip();

    this.globalAlpha = 0.16 + panel * 0.08;
    this.fillStyle = accent;
    this.fillRect(0, 0, w, h);

    for (let i = 0; i < 210; i++) {
      const x = rand(i + 101) * w;
      const y = rand(i + 201) * h;
      const len = 8 + rand(i + 301) * 64;
      const angle = -0.45 + rand(i + 401) * 0.9;

      this.globalAlpha = 0.05 + rand(i + 501) * 0.16;
      this.strokeStyle = rand(i + 601) > 0.5 ? "#d7d0c5" : "#070707";
      this.lineWidth = 0.5 + rand(i + 701) * 1.2;

      this.beginPath();
      this.moveTo(x, y);
      this.lineTo(x + Math.cos(angle) * len, y + Math.sin(angle) * len);
      this.stroke();
    }

    for (let i = 0; i < 44; i++) {
      const x = rand(i + 900) * w;
      const y = rand(i + 1000) * h;
      const rw = 1.5 + rand(i + 1100) * 4;
      const rh = 1.5 + rand(i + 1200) * 4;

      this.globalAlpha = 0.22;
      this.fillStyle = "#0a0a0a";
      this.beginPath();
      this.ellipse(x, y, rw, rh, 0, 0, Math.PI * 2);
      this.fill();

      this.globalAlpha = 0.18;
      this.fillStyle = "#d9d2c6";
      this.beginPath();
      this.ellipse(x - 1, y - 1, rw * 0.45, rh * 0.45, 0, 0, Math.PI * 2);
      this.fill();
    }

    if (grime > 0) {
      for (let i = 0; i < 24; i++) {
        const x = rand(i + 1300) * w;
        const y = rand(i + 1400) * h * 0.75;
        const len = 18 + rand(i + 1500) * 90;

        let drip = this.createLinearGradient(x, y, x, y + len);
        drip.addColorStop(0, "rgba(83,90,45,0.42)");
        drip.addColorStop(1, "rgba(83,90,45,0)");

        this.globalAlpha = 0.45 * grime;
        this.strokeStyle = drip;
        this.lineWidth = 1 + rand(i + 1600) * 3;

        this.beginPath();
        this.moveTo(x, y);
        this.bezierCurveTo(
        x + rand(i + 1700) * 10 - 5,
        y + len * 0.25,
        x + rand(i + 1800) * 10 - 5,
        y + len * 0.75,
        x + rand(i + 1900) * 10 - 5,
        y + len
        );
        this.stroke();
      }
    }

    if (rivets > 0) {
      const rivetPoints = [];

      for (let i = 0; i < 6; i++) {
        rivetPoints.push([border + 24 + i * ((w - border * 2 - 48) / 5), border + 22]);
        rivetPoints.push([border + 24 + i * ((w - border * 2 - 48) / 5), h - border - 22]);
      }

      for (let i = 0; i < 4; i++) {
        rivetPoints.push([border + 22, border + 70 + i * ((h - border * 2 - 140) / 3)]);
        rivetPoints.push([w - border - 22, border + 70 + i * ((h - border * 2 - 140) / 3)]);
      }

      rivetPoints.forEach((p, i) => {
        const x = p[0];
        const y = p[1];

        let rg = this.createRadialGradient(x - 2, y - 2, 1, x, y, 6);
        rg.addColorStop(0, "#f1eadb");
        rg.addColorStop(0.35, "#8d867b");
        rg.addColorStop(1, "#121212");

        this.globalAlpha = 0.9 * rivets;
        this.fillStyle = rg;
        this.beginPath();
        this.arc(x, y, 5, 0, Math.PI * 2);
        this.fill();

        this.globalAlpha = 0.35;
        this.fillStyle = "#000000";
        this.beginPath();
        this.arc(x + 2, y + 2, 5, 0, Math.PI * 2);
        this.fill();
      });
    }

    this.restore();

    this.globalAlpha = 1;
    this.lineWidth = 3;
    this.strokeStyle = "rgba(255,255,255,0.55)";
    drawOuterShape();
    this.stroke();

    this.lineWidth = 2;
    this.strokeStyle = "rgba(0,0,0,0.85)";
    drawInnerShape();
    this.stroke();

    this.globalAlpha = 0.65;
    this.strokeStyle = accent;
    this.lineWidth = 1;

    this.beginPath();
    this.moveTo(18, 66);
    this.lineTo(18, h - 120);
    this.stroke();

    this.globalAlpha = 1;
    this.restore();
  }
}

q-transition hudButtonHoverTransition {
  property { --hud-hover }
  delay { 0 }
  timing { ease-out }
  duration { 180 }
}

q-transition hudButtonLineTransition {
  property { --hud-line }
  delay { 0 }
  timing { ease-in-out }
  duration { 420 }
}

q-transition hudButtonActiveTransition {
  property { --hud-active }
  delay { 0 }
  timing { ease-out }
  duration { 220 }
}

q-transition hudPanelWidthTransition {
  property { width }
  delay { 80 }
  timing { cubic-bezier(0.18, 0.84, 0.24, 1) }
  duration { 720 }
}

q-transition hudPanelOpacityTransition {
  property { opacity }
  delay { 80 }
  timing { ease-out }
  duration { 360 }
}

q-transition hudPanelDentTransition {
  property { --hud-dent }
  delay { 760 }
  timing { ease-out }
  duration { 360 }
}

q-style hudRootStyle {
  width: 100%
  minHeight: 100vh
  background: #000000
  color: #e6fbff
  fontFamily: monospace
  display: block
  overflowX: hidden
  overflowY: auto
}

q-style hudResponsiveLayoutStyle {
  width: 100%
  minHeight: 100vh
  gap: 0
}

q-style hudResponsiveRowStyle {
  width: 100%
  minHeight: 100vh
  gap: 0
}

q-style hudNavColumnStyle {
  width: 300px
  minWidth: 0
  overflow: visible
}

q-style hudSpineColumnStyle {
  width: 44px
  minWidth: 0
  overflow: hidden
}

q-style hudPanelColumnStyle {
  width: "minmax(320px, 1fr)"
  minWidth: 0
  overflow: visible
}

q-style hudButtonStackStyle {
  paddingTop: 140px
  background: transparent
  display: flex
  flexDirection: column
  gap: 10px
  zIndex: 3
}

q-style hudButtonStyle {
  width: 298px
  height: 56px
  border: 0
  outline: 0
  cursor: pointer
  background: transparent
  color: #f2fbff
  fontFamily: monospace
  fontWeight: 700
  letterSpacing: 0.035em
  textAlign: center
  padding: 0 34px 0 22px
  position: relative
  overflow: hidden

  --hud-hover: 0
  --hud-active: 0
  --hud-line: 0
  --hud-accent: #6ea8ff
  --hud-warn: #ff7a18
  --hud-yellow: #f8e66b

  q-style-painter {
    background { hudButtonPainter }
  }

  q-style-transition {
    hudButtonHoverTransition
    hudButtonLineTransition
    hudButtonActiveTransition
  }
}

q-style hudButtonLabelStyle {
  position: relative
  zIndex: 2
  fontSize: 14px
  lineHeight: 56px
  whiteSpace: nowrap
}

q-style hudSpineStyle {
  height: 200vh
  width: 44px

  --hud-active: 0
  --hud-accent: #6ee7ff
  --hud-warn: #ff7a18

  q-style-painter {
    background { hudSpinePainter }
  }

  q-style-transition {
    hudButtonActiveTransition
  }
}

q-style hudPanelSlotStyle {
  height: 200vh
  display: flex
  alignItems: flex-start
  paddingTop: 0
  overflow: hidden
}

q-style hudMetalPanelStyle {
  width: 0
  height: 200vh
  maxWidth: 980px
  minHeight: 520px
  opacity: 0
  position: relative
  overflow: hidden
  marginTop: 0

  --hud-dent: 0
  --hud-panel: 1
  --hud-grime: 1
  --hud-rivets: 1
  --hud-accent: #6ee7ff

  q-style-painter {
    background { hudMetalPanelPainter }
  }

  q-style-transition {
    hudPanelWidthTransition
    hudPanelOpacityTransition
    hudPanelDentTransition
  }
}

q-style hudFrameStyle {
  position: absolute
  left: 34px
  top: 34px
  width: calc(100% - 68px);
  height: calc(100% - 94px);
  border: 0
  background: transparent
  opacity: 0.92
}

q-theme hudTheme {
  .hud-root { hudRootStyle }
  .hud-responsive-layout { hudResponsiveLayoutStyle }
  .hud-responsive-row { hudResponsiveRowStyle }
  .hud-nav-col { hudNavColumnStyle }
  .hud-spine-col { hudSpineColumnStyle }
  .hud-panel-col { hudPanelColumnStyle }
  .hud-button-stack { hudButtonStackStyle }
  .hud-button { hudButtonStyle }
  .hud-button-label { hudButtonLabelStyle }
  .hud-spine { hudSpineStyle }
  .hud-panel-slot { hudPanelSlotStyle }
  .hud-metal-panel { hudMetalPanelStyle }
  .hud-frame { hudFrameStyle }
}

q-component hud-button {
  q-property label: "TITLE 01"
  q-property url: "about:blank"
  q-property accent: "#6ea8ff"
  q-property warn: "#ff7a18"

  button.hud-button {
    type: "button"
    data-url: "${this.component.url}"
    data-label: "${this.component.label}"
    data-accent: "${this.component.accent}"
    data-warn: "${this.component.warn}"

    style {
      --hud-accent: "${this.component.accent}"
      --hud-warn: "${this.component.warn}"
    }

    onmouseenter {
      const root = this.closest("hud-system");

      if (root && root.previewButton) {
        root.previewButton(this);
      }
    }

    onmouseleave {
      const root = this.closest("hud-system");

      if (root && root.leaveButton) {
        root.leaveButton(this);
      }
    }

    onclick {
      const root = this.closest("hud-system");

      if (root && root.selectButton) {
        root.selectButton(this);
      }
    }

    span.hud-button-label {
      text { ${this.component.label} }
    }
  }
}

q-component hud-system {
  q-property panelWidth: "78vw"
  q-property defaultUrl: "about:blank"

  q-signal hudHover
  q-signal hudLeave
  q-signal hudSelect

  function dashName(name) {
    return "--" + String(name).replace(/[A-Z]/g, m => "-" + m.toLowerCase());
  }

  function setPainterProp(el, name, value) {
    if (!el) {
      return;
    }

    const raw = String(value);

    el.style.setProperty(name, raw);
    el.style.setProperty(this.dashName(name), raw);
  }

  function spine() {
    return this.querySelector(".hud-spine");
  }

  function panel() {
    return this.querySelector(".hud-metal-panel");
  }

  function iframe() {
    return this.querySelector(".hud-frame");
  }

  function emitHudSignal(name, detail) {
    if (this[name] && this[name].emit) {
      this[name].emit(detail);
      return;
    }

    this.dispatchEvent(new CustomEvent(name, {
      bubbles: true,
      detail: detail
    }));
  }

  function isCompactLayout() {
    const rect = this.getBoundingClientRect ? this.getBoundingClientRect() : null;
    const width = rect && Number.isFinite(rect.width) && rect.width > 0 ? rect.width : window.innerWidth || 0;
    return width > 0 && width < 760;
  }

  function panelTargetWidth() {
    return this.isCompactLayout() ? "100%" : this.component.panelWidth || "78vw";
  }

  function syncResponsiveLayout() {
    const compact = this.isCompactLayout();
    this.setAttribute("data-compact", compact ? "1" : "0");

    const row = this.querySelector(".hud-responsive-row");
    const navCol = this.querySelector(".hud-nav-col");
    const spineCol = this.querySelector(".hud-spine-col");
    const panelCol = this.querySelector(".hud-panel-col");
    const stack = this.querySelector(".hud-button-stack");
    const spine = this.spine();
    const panelSlot = this.querySelector(".hud-panel-slot");
    const panel = this.panel();
    const frame = this.iframe();

    if (row && row.relayout) {
      row.relayout();
    }

    if (navCol) {
      navCol.style.width = compact ? "100%" : "300px";
    }
    if (spineCol) {
      spineCol.style.width = compact ? "100%" : "44px";
    }
    if (panelCol) {
      panelCol.style.width = compact ? "100%" : "";
    }

    if (stack) {
      stack.style.paddingTop = compact ? "16px" : "140px";
      stack.style.paddingRight = compact ? "10px" : "";
      stack.style.display = compact ? "grid" : "flex";
      stack.style.gridTemplateColumns = compact ? "repeat(auto-fit, minmax(138px, 1fr))" : "";
      stack.style.gap = compact ? "8px" : "10px";
    }

    this.querySelectorAll(".hud-button").forEach(btn => {
      btn.style.width = compact ? "100%" : "298px";
      btn.style.height = compact ? "52px" : "56px";
    });

    if (spine) {
      spine.style.width = compact ? "100%" : "44px";
      spine.style.height = compact ? "18px" : "200vh";
    }

    if (panelSlot) {
      panelSlot.style.width = "100%";
      panelSlot.style.height = compact ? "78vh" : "200vh";
      panelSlot.style.overflow = compact ? "visible" : "hidden";
    }

    if (panel) {
      panel.style.height = compact ? "78vh" : "200vh";
      panel.style.minHeight = compact ? "420px" : "520px";
      panel.style.maxWidth = compact ? "100%" : "980px";
      if (panel.style.opacity === "1") {
        panel.style.width = this.panelTargetWidth();
      }
    }

    if (frame) {
      frame.style.left = compact ? "18px" : "34px";
      frame.style.top = compact ? "20px" : "34px";
      frame.style.width = compact ? "calc(100% - 36px)" : "calc(100% - 68px)";
      frame.style.height = compact ? "calc(100% - 56px)" : "calc(100% - 94px)";
    }
  }

  function previewButton(button) {
    const accent = button.getAttribute("data-accent") || "#6ea8ff";
    const warn = button.getAttribute("data-warn") || "#ff7a18";

    this.setPainterProp(button, "hudHover", "1");
    this.setPainterProp(button, "hudLine", "0.75");
    this.setPainterProp(button, "hudAccent", accent);
    this.setPainterProp(button, "hudWarn", warn);

    const s = this.spine();

    this.setPainterProp(s, "hudActive", "0.55");
    this.setPainterProp(s, "hudAccent", accent);
    this.setPainterProp(s, "hudWarn", warn);

    this.emitHudSignal("hudHover", {
      url: button.getAttribute("data-url"),
      label: button.getAttribute("data-label")
    });
  }

  function leaveButton(button) {
    if (button.getAttribute("data-active") === "1") {
      return;
    }

    this.setPainterProp(button, "hudHover", "0");
    this.setPainterProp(button, "hudLine", "0");

    const selected = this.querySelector(".hud-button[data-active='1']");

    if (!selected) {
      this.setPainterProp(this.spine(), "hudActive", "0");
    }

    this.emitHudSignal("hudLeave", {
      url: button.getAttribute("data-url"),
      label: button.getAttribute("data-label")
    });
  }

  function selectButton(button) {
    const url = button.getAttribute("data-url") || this.component.defaultUrl || "about:blank";
    const label = button.getAttribute("data-label") || "";
    const accent = button.getAttribute("data-accent") || "#6ea8ff";
    const warn = button.getAttribute("data-warn") || "#ff7a18";

    this.querySelectorAll(".hud-button").forEach(btn => {
      btn.setAttribute("data-active", "0");

      this.setPainterProp(btn, "hudActive", "0");
      this.setPainterProp(btn, "hudHover", "0");
      this.setPainterProp(btn, "hudLine", "0");
    });

    button.setAttribute("data-active", "1");

    this.setPainterProp(button, "hudActive", "1");
    this.setPainterProp(button, "hudHover", "1");
    this.setPainterProp(button, "hudLine", "1");

    const s = this.spine();

    this.setPainterProp(s, "hudActive", "1");
    this.setPainterProp(s, "hudAccent", accent);
    this.setPainterProp(s, "hudWarn", warn);

    const p = this.panel();

    this.setPainterProp(p, "hudAccent", accent);
    this.setPainterProp(p, "hudDent", "1");
    this.setPainterProp(p, "hudPanel", "1");

    p.style.width = this.panelTargetWidth();
    p.style.opacity = "1";

    const frame = this.iframe();

    if (frame) {
      frame.setAttribute("src", url);
    }

    this.emitHudSignal("hudSelect", {
      url: url,
      label: label
    });

    this.syncResponsiveLayout();
  }

  onReady {
    this.syncResponsiveLayout();

    const selectedButton = this.querySelector(".hud-button[data-active='1']") || this.querySelector(".hud-button");
    if (selectedButton) {
      this.selectButton(selectedButton);
    }

    if (this.__hudResponsiveObserver) {
      this.__hudResponsiveObserver.disconnect();
    }

    if (window.ResizeObserver) {
      this.__hudResponsiveObserver = new ResizeObserver(() => this.syncResponsiveLayout());
      this.__hudResponsiveObserver.observe(this);
    } else if (!this.__hudResponsiveResizeHandler) {
      this.__hudResponsiveResizeHandler = () => this.syncResponsiveLayout();
      window.addEventListener("resize", this.__hudResponsiveResizeHandler);
    }
  }

  hudTheme {
    div.hud-root {
      q-layout.hud-responsive-layout {
        width: "100%"
        gap: "0"
        q-row.hud-responsive-row {
          stackAt: "760px"
          minColWidth: "320px"
          gap: "0"
          q-col.hud-nav-col {
            width: "300px"
            aside.hud-button-stack {
              slot { buttons }
            }
          }
          q-col.hud-spine-col {
            width: "44px"
            div.hud-spine { }
          }
          q-col.hud-panel-col {
            width: "minmax(320px, 1fr)"
            div.hud-panel-slot {
              div.hud-metal-panel {
                iframe.hud-frame {
                  src: "${this.component.defaultUrl}"
                }
              }
            }
          }
        }
      }
    }
  }
}
/* usage pattern 


hud-system {
  panelWidth: "78vw"
  defaultUrl: "about:blank"

  buttons {
    hud-button {
      label: "TITLE 01"
      url: "https://datafault.net/"
      accent: "#6ea8ff"
      warn: "#ff7a18"
    }

    hud-button {
      label: "TITLE 02"
      url: "https://datafault.net/tools/"
      accent: "#6ee7ff"
      warn: "#facc15"
    }

    hud-button {
      label: "TITLE 03"
      url: "https://datafault.net/stats/"
      accent: "#93c5fd"
      warn: "#fb7185"
    }

    hud-button {
      label: "TITLE 04"
      url: "https://datafault.net/search/"
      accent: "#67e8f9"
      warn: "#f97316"
    }
  }
}
*/

q-painter hudContainerTopLinePainter {
  q-property hudAccent: "#6ea8ff"
  q-property hudWarn: "#ff3b18"
  q-property hudYellow: "#d49a36"
  q-property hudLineAlpha: "0.9"
  q-property hudLineScale: "1"

  onpaint {
    const n = (v, d) => {
      const x = parseFloat(String(v ?? d));
      return Number.isFinite(x) ? x : d;
    };

    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
    const read = (camel, css, fallback) => this[camel] ?? this[css] ?? fallback;

    const w = this.width;
    const h = this.height;

    const accent = String(read("hudAccent", "--hud-accent", "#6ea8ff"));
    const warn = String(read("hudWarn", "--hud-warn", "#ff3b18"));
    const yellow = String(read("hudYellow", "--hud-yellow", "#d49a36"));
    const alpha = clamp(n(read("hudLineAlpha", "--hud-line-alpha", 0.9), 0.9), 0, 1);
    const lineScale = clamp(n(read("hudLineScale", "--hud-line-scale", 1), 1), 0.25, 4);

    const sx = w / 760;
    const sy = h / 106;
    const s = Math.min(sx, sy) * lineScale;

    const strokePath = (yOffset, color, opacity, width) => {
      this.globalAlpha = opacity * alpha;
      this.strokeStyle = color;
      this.lineWidth = width * s;
      this.lineJoin = "miter";
      this.lineCap = "butt";

      this.beginPath();
      this.moveTo(24 * sx, 78 * sy + yOffset);
      this.lineTo(148 * sx, 78 * sy + yOffset);
      this.lineTo(184 * sx, 46 * sy + yOffset);
      this.lineTo(360 * sx, 46 * sy + yOffset);
      this.lineTo(390 * sx, 24 * sy + yOffset);
      this.lineTo(524 * sx, 24 * sy + yOffset);
      this.lineTo(554 * sx, 48 * sy + yOffset);
      this.lineTo(w - 74 * sx, 48 * sy + yOffset);
      this.lineTo(w - 74 * sx, h - 8 * sy + yOffset);
      this.stroke();
    };

    this.save();
    this.clearRect(0, 0, w, h);

    strokePath(0, "#8ba7c2", 0.86, 4.2);
    strokePath(10 * sy, accent, 0.72, 2.4);
    strokePath(20 * sy, "#34546a", 0.58, 1.8);

    this.globalAlpha = 0.78 * alpha;
    this.strokeStyle = "#b7c9d8";
    this.lineWidth = 2 * s;
    this.beginPath();
    this.moveTo(185 * sx, 56 * sy);
    this.lineTo(348 * sx, 56 * sy);
    this.lineTo(374 * sx, 36 * sy);
    this.lineTo(512 * sx, 36 * sy);
    this.stroke();

    this.globalAlpha = 0.85 * alpha;
    this.strokeStyle = yellow;
    this.lineWidth = 5 * s;
    for (let i = 0; i < 3; i++) {
      const x = 58 * sx + i * 34 * sx;
      this.beginPath();
      this.moveTo(x, 18 * sy);
      this.lineTo(x + 22 * sx, 4 * sy);
      this.stroke();
    }

    this.globalAlpha = 0.82 * alpha;
    this.strokeStyle = yellow;
    this.lineWidth = 5 * s;
    for (let i = 0; i < 2; i++) {
      const x = w - 118 * sx + i * 28 * sx;
      this.beginPath();
      this.moveTo(x, 8 * sy);
      this.lineTo(x + 24 * sx, 32 * sy);
      this.stroke();
    }

    this.globalAlpha = 0.85 * alpha;
    this.strokeStyle = accent;
    this.lineWidth = 3 * s;
    this.beginPath();
    this.moveTo(w - 112 * sx, 54 * sy);
    this.lineTo(w - 56 * sx, 54 * sy);
    this.stroke();

    this.globalAlpha = 0.9 * alpha;
    this.strokeStyle = "#2dd4bf";
    this.lineWidth = 3 * s;
    this.strokeRect(336 * sx, 38 * sy, 8 * sx, 8 * sy);

    this.globalAlpha = 0.52 * alpha;
    this.strokeStyle = "#8ba7c2";
    this.lineWidth = 2 * s;
    for (let i = 0; i < 5; i++) {
      const x = 498 * sx + i * 14 * sx;
      this.beginPath();
      this.moveTo(x, 74 * sy);
      this.lineTo(x + 5 * sx, 74 * sy);
      this.stroke();
    }

    this.globalAlpha = 0.46 * alpha;
    this.strokeStyle = warn;
    this.lineWidth = 2 * s;
    this.beginPath();
    this.moveTo(w - 76 * sx, 90 * sy);
    this.lineTo(w - 42 * sx, 90 * sy);
    this.stroke();

    this.globalAlpha = 1;
    this.restore();
  }
}

q-painter hudContainerBottomLinePainter {
  q-property hudAccent: "#6ea8ff"
  q-property hudLineAlpha: "0.9"
  q-property hudLineScale: "1"

  onpaint {
    const n = (v, d) => {
      const x = parseFloat(String(v ?? d));
      return Number.isFinite(x) ? x : d;
    };

    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
    const read = (camel, css, fallback) => this[camel] ?? this[css] ?? fallback;

    const w = this.width;
    const h = this.height;

    const accent = String(read("hudAccent", "--hud-accent", "#6ea8ff"));
    const alpha = clamp(n(read("hudLineAlpha", "--hud-line-alpha", 0.9), 0.9), 0, 1);
    const lineScale = clamp(n(read("hudLineScale", "--hud-line-scale", 1), 1), 0.25, 4);

    const sx = w / 760;
    const sy = h / 78;
    const s = Math.min(sx, sy) * lineScale;

    this.save();
    this.clearRect(0, 0, w, h);

    this.globalAlpha = 0.84 * alpha;
    this.strokeStyle = "#8ba7c2";
    this.lineWidth = 4 * s;
    this.lineJoin = "miter";
    this.lineCap = "butt";

    this.beginPath();
    this.moveTo(0, 40 * sy);
    this.lineTo(128 * sx, 40 * sy);
    this.lineTo(160 * sx, 22 * sy);
    this.lineTo(462 * sx, 22 * sy);
    this.lineTo(494 * sx, 50 * sy);
    this.lineTo(612 * sx, 50 * sy);
    this.lineTo(650 * sx, 28 * sy);
    this.lineTo(w - 36 * sx, 28 * sy);
    this.stroke();

    this.globalAlpha = 0.72 * alpha;
    this.strokeStyle = accent;
    this.lineWidth = 2.4 * s;

    this.beginPath();
    this.moveTo(0, 48 * sy);
    this.lineTo(132 * sx, 48 * sy);
    this.lineTo(164 * sx, 30 * sy);
    this.lineTo(456 * sx, 30 * sy);
    this.lineTo(488 * sx, 58 * sy);
    this.lineTo(616 * sx, 58 * sy);
    this.lineTo(654 * sx, 36 * sy);
    this.lineTo(w - 36 * sx, 36 * sy);
    this.stroke();

    this.globalAlpha = 0.46 * alpha;
    this.strokeStyle = "#8ba7c2";
    this.lineWidth = 5 * s;

    for (let i = 0; i < 8; i++) {
      const x = 236 * sx + i * 32 * sx;
      this.beginPath();
      this.moveTo(x, 26 * sy);
      this.lineTo(x + 34 * sx, 62 * sy);
      this.stroke();
    }

    this.globalAlpha = 0.36 * alpha;
    this.strokeStyle = "#b7c9d8";
    this.lineWidth = 1.4 * s;
    this.beginPath();
    this.moveTo(180 * sx, 12 * sy);
    this.lineTo(460 * sx, 12 * sy);
    this.stroke();

    this.globalAlpha = 1;
    this.restore();
  }
}

q-painter hudContainerRightLinePainter {
  q-property hudAccent: "#6ea8ff"
  q-property hudWarn: "#ff3b18"
  q-property hudLineAlpha: "0.9"
  q-property hudLineScale: "1"

  onpaint {
    const n = (v, d) => {
      const x = parseFloat(String(v ?? d));
      return Number.isFinite(x) ? x : d;
    };

    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
    const read = (camel, css, fallback) => this[camel] ?? this[css] ?? fallback;

    const w = this.width;
    const h = this.height;

    const accent = String(read("hudAccent", "--hud-accent", "#6ea8ff"));
    const warn = String(read("hudWarn", "--hud-warn", "#ff3b18"));
    const alpha = clamp(n(read("hudLineAlpha", "--hud-line-alpha", 0.9), 0.9), 0, 1);
    const lineScale = clamp(n(read("hudLineScale", "--hud-line-scale", 1), 1), 0.25, 4);

    const s = lineScale;

    this.save();
    this.clearRect(0, 0, w, h);

    this.globalAlpha = 0.86 * alpha;
    this.strokeStyle = "#8ba7c2";
    this.lineWidth = 4 * s;
    this.lineJoin = "miter";
    this.lineCap = "butt";

    this.beginPath();
    this.moveTo(8, 8);
    this.lineTo(w - 16, 8);
    this.lineTo(w - 16, h - 10);
    this.stroke();

    this.globalAlpha = 0.72 * alpha;
    this.strokeStyle = accent;
    this.lineWidth = 2.2 * s;

    this.beginPath();
    this.moveTo(16, 18);
    this.lineTo(w - 26, 18);
    this.lineTo(w - 26, h - 22);
    this.stroke();

    this.globalAlpha = 0.82 * alpha;
    this.strokeStyle = warn;
    this.lineWidth = 5 * s;

    for (let i = 0; i < 3; i++) {
      const y = h * 0.44 + i * 30;
      this.beginPath();
      this.moveTo(w - 42, y);
      this.lineTo(w - 72, y + 26);
      this.stroke();
    }

    this.globalAlpha = 0.38 * alpha;
    this.strokeStyle = "#b7c9d8";
    this.lineWidth = 1.5 * s;
    this.beginPath();
    this.moveTo(w - 18, 34);
    this.lineTo(w - 18, h - 38);
    this.stroke();

    this.globalAlpha = 1;
    this.restore();
  }
}

q-style hudContainerRootStyle {
  display: grid
  gridTemplateColumns: "var(--hud-left-overhang) minmax(0, 1fr) var(--hud-right-overhang)"
  gridTemplateRows: var(--hud-top-height) auto var(--hud-bottom-height);
  position: relative
  width: 100%
  minWidth: 0
  height: fit-content
  boxSizing: border-box
  background: transparent
  isolation: isolate

  --hud-left-overhang: 28px
  --hud-right-overhang: 96px
  --hud-top-height: 106px
  --hud-bottom-height: 78px
  --hud-accent: #6ea8ff
  --hud-warn: #ff3b18
  --hud-yellow: #d49a36
  --hud-line-alpha: 0.9
  --hud-line-scale: 1
}

q-style hudContainerTopStyle {
  gridColumn: 1 / 4;
  gridRow: 1
  position: relative
  zIndex: 3
  pointerEvents: none
  background: transparent

  q-style-painter {
    background { hudContainerTopLinePainter }
  }
}

q-style hudContainerBottomStyle {
  gridColumn: 1 / 4;
  gridRow: 3
  position: relative
  zIndex: 3
  pointerEvents: none
  background: transparent

  q-style-painter {
    background { hudContainerBottomLinePainter }
  }
}

q-style hudContainerRightHookStyle {
  gridColumn: 3
  gridRow: 1 / 3;
  position: relative
  zIndex: 4
  pointerEvents: none
  background: transparent

  q-style-painter {
    background { hudContainerRightLinePainter }
  }
}

q-style hudContainerBodyStyle {
  gridColumn: 2
  gridRow: 2
  position: relative
  zIndex: 2
  width: 100%
  minWidth: 1px
  minHeight: 1px
  overflow: visible
  background: transparent
}

q-style hudContainerInnerStyle {
  position: relative
  zIndex: 2
  width: 100%
  minWidth: 0
  height: fit-content
  background: transparent
}

q-theme hudContainerTheme {
  .hud-container-root { hudContainerRootStyle }
  .hud-container-top { hudContainerTopStyle }
  .hud-container-bottom { hudContainerBottomStyle }
  .hud-container-right-hook { hudContainerRightHookStyle }
  .hud-container-body { hudContainerBodyStyle }
  .hud-container-inner { hudContainerInnerStyle }
}

q-component hud-container {
  q-property accent: "#6ea8ff"
  q-property warn: "#ff3b18"
  q-property yellow: "#d49a36"
  q-property lineAlpha: "0.9"
  q-property lineScale: "1"
  q-property topHeight: "106px"
  q-property bottomHeight: "78px"
  q-property leftOverhang: "28px"
  q-property rightOverhang: "96px"

  q-signal hudContainerResize

  hudContainerTheme {
    div.hud-container-root {
      style {
        --hud-accent: "${this.component.accent}"
        --hud-warn: "${this.component.warn}"
        --hud-yellow: "${this.component.yellow}"
        --hud-line-alpha: "${this.component.lineAlpha}"
        --hud-line-scale: "${this.component.lineScale}"
        --hud-top-height: "${this.component.topHeight}"
        --hud-bottom-height: "${this.component.bottomHeight}"
        --hud-left-overhang: "${this.component.leftOverhang}"
        --hud-right-overhang: "${this.component.rightOverhang}"
      }

      onReady {
        const root = this;
        const host = root.closest("hud-container");
        const body = root.querySelector(".hud-container-body");

        if (!body) {
          return;
        }

        const emitResize = detail => {
          if (host && host.hudContainerResize && host.hudContainerResize.emit) {
            host.hudContainerResize.emit(detail);
            return;
          }

          if (host) {
            host.dispatchEvent(new CustomEvent("hudContainerResize", {
              bubbles: true,
              detail: detail
            }));
          }
        };

        const sync = () => {
          const rect = body.getBoundingClientRect();

          root.style.setProperty("--hud-content-width", rect.width + "px");
          root.style.setProperty("--hud-content-height", rect.height + "px");

          emitResize({
            width: rect.width,
            height: rect.height
          });
        };

        if (root.__hudContainerResizeObserver) {
          root.__hudContainerResizeObserver.disconnect();
        }

        const observer = new ResizeObserver(sync);
        observer.observe(body);

        Array.from(body.children || []).forEach(child => {
          observer.observe(child);
        });

        root.__hudContainerResizeObserver = observer;

        requestAnimationFrame(sync);
      }

      div.hud-container-top { }

      div.hud-container-right-hook { }

      div.hud-container-body {
        div.hud-container-inner {
          slot { content }
        }
      }

      div.hud-container-bottom { }
    }
  }
}

q-component q-list-view {
