    function drawSideVent(ctx, x, y, w, h, side) {
      if (h < 24 || w < 4) {
        return;
      }
      ctx.save();
      roundedPath(ctx, x, y, w, h, Math.min(10, w * 0.45, h * 0.18));
      var g = ctx.createLinearGradient(x, y, x + w, y);
      g.addColorStop(0, side < 0 ? "#020203" : "#4d504d");
      g.addColorStop(0.35, "#565955");
      g.addColorStop(0.52, "#111314");
      g.addColorStop(1, side < 0 ? "#4d504d" : "#020203");
      ctx.fillStyle = g;
      ctx.fill();
      ctx.clip();

      var slotStep = Math.max(8, h / 10.5);
      var slotHeight = Math.max(3, slotStep * 0.5);
      for (var i = 0; i < 9; i += 1) {
        var yy = y + Math.max(5, slotStep * 0.85) + (i * slotStep);
        if (yy + slotHeight > y + h - 3) {
          break;
        }
        ctx.fillStyle = "#090a0b";
        ctx.fillRect(x - 2, yy, w + 4, slotHeight);
        ctx.fillStyle = "rgba(220,220,210,.28)";
        ctx.fillRect(x + Math.max(2, w * 0.1), yy - 1, Math.max(1, w * 0.8), 1.5);
      }

      ctx.restore();
      metalStroke(ctx, function() { roundedPath(ctx, x, y, w, h, Math.min(10, w * 0.45, h * 0.18)); }, Math.max(1, Math.min(3, w * 0.1)), "rgba(210,210,200,.7)", 0);
      metalStroke(ctx, function() { roundedPath(ctx, x + 3, y + 3, Math.max(1, w - 6), Math.max(1, h - 6), Math.min(7, w * 0.36, h * 0.14)); }, Math.max(1, Math.min(3, w * 0.1)), "rgba(0,0,0,.9)", 0);
    }

    function drawSideHazardStrip(ctx, x, y, w, h, rng) {
      if (h < 24 || w < 3) {
        return;
      }
      ctx.save();
      ctx.beginPath();
      ctx.rect(x, y, w, h);
      ctx.clip();
      ctx.fillStyle = "#0b0b08";
      ctx.fillRect(x - (w * 0.3), y - 6, w * 1.8, h + 12);

      var stripeStep = Math.max(12, w * 1.7);
      for (var i = -h; i < h + stripeStep; i += stripeStep) {
        ctx.save();
        ctx.translate(x, y + i);
        ctx.rotate(0.62);
        ctx.fillStyle = "#d8b10e";
        ctx.fillRect(-w * 2.2, 0, w * 4.8, Math.max(4, w * 0.72));
