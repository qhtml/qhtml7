q-component q-modal {
  function ensureOpenState() {
    if (typeof this.__isOpen !== "boolean") {
      this.__isOpen = false;
    }
    return this.__isOpen;
  }

  function modalRoot() {
    return this.querySelector("[q-modal-root='1']");
  }

  function setOpen(nextState) {
    this.__isOpen = !!nextState;
    this.isOpen = this.__isOpen;
    var root = this.modalRoot();
    if (root && root.style) {
      root.style.display = this.__isOpen ? "block" : "none";
    }
    return this.__isOpen;
  }

  function show() {
    this.setOpen(true);
  }

  function hide() {
    this.setOpen(false);
  }

  function toggle() {
    this.setOpen(!this.ensureOpenState());
  }

  onReady {
    this.ensureOpenState();
    this.hide();
  }

  q-modal-theme {
    div.q-modal-root {
      q-modal-root: "1"
      style { display: none; }

      div.q-modal-container {
        style { max-width: 600px; }

        div.q-modal-titlebar {
          br { }
          span.q-modal-closebutton {
            q-modal-close-trigger: "1"
            title: "Close Modal"
            onclick { this.closest("q-modal").hide(); }
            html { &times; }
          }
          div.q-modal-title {
            slot { title }
            slot { heading }
            slot { header }
          }
        }

        div.q-modal-content {
          slot { body }
          slot { main }
          slot { content }
        }

        div.q-modal-footer {
          slot { bottom }
          slot { footer }
          slot { foot }
        }
      }
    }
  }
}

q-style q-popup-floating-div-style { position: fixed; width: 100%; height: 100%; }
q-style q-popup-visible-style { display: block;  }
