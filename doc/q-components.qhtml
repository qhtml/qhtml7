      bottomRight: normalizePair(this.bottomRight, canvasHeight, canvasWidth),
      bottomLeft: normalizePair(this.bottomLeft, canvasHeight, canvasWidth),
      patternShift: normalizePair(this.patternShift, canvasHeight, canvasWidth),
      topDent: normalizeCssValue(this.topDent, canvasHeight, 0),
