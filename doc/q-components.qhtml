    function drawRivet(ctx, x, y, r) {
      var g = ctx.createRadialGradient(x - (r * 0.45), y - (r * 0.45), 0, x, y, r * 1.5);
      g.addColorStop(0, "#eeeeea");
      g.addColorStop(0.24, "#9c9d98");
      g.addColorStop(0.72, "#282b2c");
      g.addColorStop(1, "#050606");
