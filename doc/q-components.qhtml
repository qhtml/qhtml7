      ctx.globalAlpha = 0.45;
      drawBrushedLines(ctx, rng, x, y, w, h, Math.max(16, Math.floor(h / 3)), 0.22, false);
      ctx.restore();

      ctx.save();
      ctx.strokeStyle = "rgba(210,210,200,.8)";
      ctx.lineWidth = Math.max(1, w * 0.14);
      ctx.beginPath();
      ctx.moveTo(x + w, y);
      ctx.lineTo(x + w, y + h);
      ctx.stroke();
      ctx.restore();
