    return this.querySelector("[q-drag-handle='1']") || this;
  }

  function handleDragStart(event) {
    if (!event || (event.button != null && event.button !== 0)) {
      return;
    }

    var start = this.getBoundingClientRect ? this.getBoundingClientRect() : { left: 0, top: 0 };
    this.__dragState = {
      mouseX: Number(event.clientX || 0),
      mouseY: Number(event.clientY || 0),
      startLeft: Number(start.left || 0),
      startTop: Number(start.top || 0)
    };

    var win = this.ownerDocument && this.ownerDocument.defaultView ? this.ownerDocument.defaultView : window;
    if (!this.__dragMoveHandler) {
      var host = this;
      this.__dragMoveHandler = function(moveEvent) {
        if (!host.__dragState) {
          return;
        }
        var dx = Number(moveEvent.clientX || 0) - host.__dragState.mouseX;
        var dy = Number(moveEvent.clientY || 0) - host.__dragState.mouseY;
        host.applyPosition(host.__dragState.startLeft + dx, host.__dragState.startTop + dy);
      };
    }

    if (!this.__dragEndHandler) {
      var hostEnd = this;
      this.__dragEndHandler = function() {
        hostEnd.__dragState = null;
        win.removeEventListener("mousemove", hostEnd.__dragMoveHandler);
        win.removeEventListener("mouseup", hostEnd.__dragEndHandler);
      };
    }

    win.addEventListener("mousemove", this.__dragMoveHandler);
    win.addEventListener("mouseup", this.__dragEndHandler);

    if (typeof event.preventDefault === "function") {
      event.preventDefault();
    }
  }

  function setupDragging() {
    if (this.__dragReady) {
      return;
    }
    this.__dragReady = true;

    var handle = this.dragHandle();
    if (!handle || typeof handle.addEventListener !== "function") {
      return;
    }

    var host = this;
    this.__dragStartHandler = function(event) {
      host.handleDragStart(event);
    };

    handle.addEventListener("mousedown", this.__dragStartHandler);
  }

  onReady {
    this.setupDragging();
    this.applyPosition(this.x, this.y);
  }
}
q-component q-resizable-item {
  q-property { width height }

  function numberOr(value, fallback) {
    var n = Number(value);
    if (!Number.isFinite(n)) {
      return Number(fallback);
    }
    return n;
  }

  function minWidth() {
    return 64;
  }

  function minHeight() {
    return 44;
  }

  function afterResize(width, height) {
    return { width: width, height: height };
  }

  function applySize(rawWidth, rawHeight) {
    var nextWidth = Math.max(this.minWidth(), Math.round(this.numberOr(rawWidth, this.width == null ? 320 : this.width)));
    var nextHeight = Math.max(this.minHeight(), Math.round(this.numberOr(rawHeight, this.height == null ? 56 : this.height)));

    this.width = nextWidth;
    this.height = nextHeight;

    if (this.style) {
      this.style.width = String(nextWidth) + "px";
      this.style.height = String(nextHeight) + "px";
      this.style.boxSizing = "border-box";
    }

    this.afterResize(nextWidth, nextHeight);
    return { width: nextWidth, height: nextHeight };
  }

  function resizeHandle() {
    return this.querySelector("[q-resize-handle='1']") || this;
  }

  function handleResizeStart(event) {
    if (!event || (event.button != null && event.button !== 0)) {
      return;
    }

    var rect = this.getBoundingClientRect ? this.getBoundingClientRect() : { width: this.width || 320, height: this.height || 56 };
    this.__resizeState = {
      mouseX: Number(event.clientX || 0),
      mouseY: Number(event.clientY || 0),
      startWidth: Number(rect.width || this.width || 320),
      startHeight: Number(rect.height || this.height || 56)
    };

    var win = this.ownerDocument && this.ownerDocument.defaultView ? this.ownerDocument.defaultView : window;
    if (!this.__resizeMoveHandler) {
      var host = this;
      this.__resizeMoveHandler = function(moveEvent) {
        if (!host.__resizeState) {
          return;
        }
        var dx = Number(moveEvent.clientX || 0) - host.__resizeState.mouseX;
        var dy = Number(moveEvent.clientY || 0) - host.__resizeState.mouseY;
        host.applySize(host.__resizeState.startWidth + dx, host.__resizeState.startHeight + dy);
      };
    }

    if (!this.__resizeEndHandler) {
      var hostEnd = this;
      this.__resizeEndHandler = function() {
        hostEnd.__resizeState = null;
        win.removeEventListener("mousemove", hostEnd.__resizeMoveHandler);
        win.removeEventListener("mouseup", hostEnd.__resizeEndHandler);
      };
    }

    win.addEventListener("mousemove", this.__resizeMoveHandler);
    win.addEventListener("mouseup", this.__resizeEndHandler);

    if (typeof event.preventDefault === "function") {
      event.preventDefault();
    }
  }

  function setupResizing() {
    if (this.__resizeReady) {
      return;
    }
    this.__resizeReady = true;

    var handle = this.resizeHandle();
    if (!handle || typeof handle.addEventListener !== "function") {
      return;
    }

    var host = this;
    this.__resizeStartHandler = function(event) {
      host.handleResizeStart(event);
    };

    handle.addEventListener("mousedown", this.__resizeStartHandler);
  }

  onReady {
    this.setupResizing();
    this.applySize(this.width, this.height);
  }
}

q-component q-toolbutton {
  q-property src: ""
  q-property label: ""
  q-property size: 44

  function numberOr(value, fallback) {
    var parsed = Number(value);
    if (!Number.isFinite(parsed)) {
      return Number(fallback);
    }
    return parsed;
  }

  function applySize(rawSize) {
    var nextSize = Math.max(24, Math.round(this.numberOr(rawSize, this.size || 44)));
    this.size = nextSize;
    this.style.setProperty("--q-toolbutton-size", String(nextSize) + "px");
    return nextSize;
  }

  function setSize(rawSize) {
    return this.applySize(rawSize);
  }

  onReady {
    this.applySize(this.size);
  }

  button.q-toolbutton-root {
    q-toolbutton-root: "1"
    type: "button"
    title: "${this.component.label}"
    aria-label: "${this.component.label}"
    style {
      width: var(--q-toolbutton-size, 44px);
      height: var(--q-toolbutton-size, 44px);
      padding: 6px;
      margin: 0;
      border: 1px solid #94a3b8;
      border-radius: 8px;
      background: #f8fafc;
      cursor: pointer;
      display: inline-grid;
      place-items: center;
      box-sizing: border-box;
    }

    img.q-toolbutton-image {
      q-toolbutton-image: "1"
      src: "${this.component.src}"
      alt: "${this.component.label}"
      draggable: "false"
      style {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
        pointer-events: none;
      }
    }

    slot { content }
  }
}

q-component q-tree-view {
  q-property model: ""
  q-property treeModel: ""

  function _normalizeSetModelInput(input) {
    if (input && typeof input === "object") {
      return input
    }
    if (typeof input === "string") {
      var text = String(input || "").trim()
      if (!text) {
        return {}
      }
      try {
        return JSON.parse(text)
      } catch (error) {
        return {}
      }
    }
    return {}
  }

  function setModel(qdomModel) {
    var normalized = this._normalizeSetModelInput(qdomModel)
    this.__treeRawModel = normalized
    this.treeModel = ""
    this.model = ""
    this.refresh()
    return normalized
  }

  function _effectiveModel() {
    if (this.__treeRawModel && typeof this.__treeRawModel === "object") {
      return this.__treeRawModel
    }
    var value = this.treeModel
    if (value === null || typeof value === "undefined" || value === "") { value = this.model }
    if (value === null || typeof value === "undefined" || value === "") { value = this.getAttribute("treeModel") }
    if (value === null || typeof value === "undefined" || value === "") { value = this.getAttribute("model") }
    return value
  }

  function _unbindModelObserver() {
    if (typeof this.__treeModelUnsubscribe === "function") {
      this.__treeModelUnsubscribe()
    }
    this.__treeModelUnsubscribe = null
    this.__treeObservedModel = null
  }

  function _bindModelObserver(modelValue) {
    if (!modelValue || typeof modelValue.subscribe !== "function") {
      this._unbindModelObserver()
      return
    }
    if (this.__treeObservedModel === modelValue && typeof this.__treeModelUnsubscribe === "function") {
      return
    }
    this._unbindModelObserver()
    var component = this
    this.__treeModelUnsubscribe = modelValue.subscribe(function() {
      component.refresh()
    })
    this.__treeObservedModel = modelValue
  }

  function _normalizeBranches() {
    var component = this
    function setBranchState(branchNode, summaryNode, openState) {
      if (!branchNode || !summaryNode) { return }
      var open = openState === true
      var marker = summaryNode.querySelector(".q-tree-marker")
      var children = branchNode.querySelector(".q-tree-children")
      branchNode.open = open
      branchNode.setAttribute("q-tree-open", open ? "1" : "0")
      if (children) { children.style.display = open ? "block" : "none" }
      if (marker) {
        marker.className = "q-tree-marker " + (open ? "q-tree-marker-open" : "q-tree-marker-closed")
        marker.textContent = open ? "-" : "+"
      }
    }
    var detailsBranches = component.querySelectorAll("details.q-tree-branch")
    var i = 0
    while (i < detailsBranches.length) {
      var details = detailsBranches[i]
      var summary = details.querySelector(":scope > .q-tree-summary")
      var children = details.querySelector(":scope > .q-tree-children")
      if (summary && children) {
        if (String(summary.tagName || "").toLowerCase() !== "summary") {
          var realSummary = document.createElement("summary")
          realSummary.className = summary.className
          while (summary.firstChild) {
            realSummary.appendChild(summary.firstChild)
          }
          details.replaceChild(realSummary, summary)
          summary = realSummary
        }
        setBranchState(details, summary, details.open === true)
      }
      i += 1
    }
  }

  function _queueNormalizeBranches() {
    var component = this
    if (typeof component.__normalizeRaf === "number") {
      cancelAnimationFrame(component.__normalizeRaf)
    }
    component.__normalizeRaf = requestAnimationFrame(function() {
      component.__normalizeRaf = null
      component._normalizeBranches()
    })
  }

  function refresh() {
    var host = (typeof this.qhtmlRoot === "function" ? this.qhtmlRoot() : this.qhtmlRoot) || this.closest("q-html")
    var root = this.querySelector("[q-tree-root='1']")
    if (!root || typeof root.qdom !== "function") { return }
    var modelInput = this._effectiveModel()
    this._bindModelObserver(modelInput)
    var rootQdom = root.qdom()
    if (!rootQdom || typeof rootQdom.createQTreeSource !== "function") { return }
    var body = rootQdom.createQTreeSource(modelInput, { host: host, targetElement: this })
    rootQdom.replaceWithQHTML("ul.q-tree.q-tree-list { q-tree-root: \"1\" " + body + " }")
    this._queueNormalizeBranches()
  }

  onReady { this.refresh() }

  ul.q-tree.q-tree-list { q-tree-root: "1" }
}

q-component sdml-object {
  q-property url: ""
  q-property data: ""
  q-property method: "GET"

  q-signal response(url, data)
  q-signal error(url, error)
  q-signal request(url, method, data)

  function ensureComponentBridge() {
    const host = this;
    if (!host || (typeof host !== "object" && typeof host !== "function")) {
      return null;
    }
    if (host.__sdmlComponentBridgeReady && host.component) {
      return host.component;
    }
    if (typeof Proxy !== "function") {
      host.component = host;
      host.__sdmlComponentBridgeReady = true;
      return host.component;
    }

    const bridgeCallable = function componentBridge(handler) {
      if (typeof handler === "function") {
        return handler.bind(host);
      }
      return host;
    };

    const bridge = new Proxy(bridgeCallable, {
      get(target, property) {
        if (property === "__host") {
          return host;
        }
        if (property in host) {
          return host[property];
        }
        return target[property];
      },
      set(target, property, value) {
        host[property] = value;
        return true;
      },
      apply(target, thisArg, args) {
        if (Array.isArray(args) && args.length > 0 && typeof args[0] === "function") {
          return args[0].bind(host);
        }
        return host;
      },
    });

    host.component = bridge;
    host.__sdmlComponentBridgeReady = true;
    return bridge;
  }

  function interpolateTemplateString(source) {
    const body = String(source || "");
    const marker = "$" + "{";
    if (!body || body.indexOf(marker) === -1) {
      return body;
    }
    let output = "";
    let cursor = 0;
    while (cursor < body.length) {
      const start = body.indexOf(marker, cursor);
      if (start === -1) {
        output += body.slice(cursor);
        break;
      }
      output += body.slice(cursor, start);
      const end = body.indexOf("}", start + 2);
      if (end === -1) {
        output += body.slice(start);
        break;
      }
      const expression = body.slice(start + 2, end).trim();
      try {
        const evaluate = new Function(
          "component",
          "self",
          "with({component: component, self: self, this: component}){ return (" + expression + "); }"
        );
        const value = evaluate.call(this, this, this);
        if (typeof value === "string") {
          output += JSON.stringify(value);
        } else if (value && typeof value === "object") {
          output += JSON.stringify(value);
        } else if (value == null) {
          output += "null";
        } else {
          output += String(value);
        }
      } catch (error) {
        output += "null";
      }
      cursor = end + 1;
    }
    return output;
  }

  function normalizePayload(rawPayload) {
    if (typeof rawPayload !== "string") {
      return rawPayload;
    }
    const interpolated = this.interpolateTemplateString(rawPayload);
    const text = String(interpolated || "").trim();
    if (!text) {
      return "";
    }
    if ((text.charAt(0) === "{" && text.charAt(text.length - 1) === "}") ||
        (text.charAt(0) === "[" && text.charAt(text.length - 1) === "]")) {
      try {
        return JSON.parse(text);
      } catch (jsonError) {
        try {
          return (new Function("return (" + text + ");"))();
        } catch (jsObjectError) {
          return text;
        }
      }
    }
    return text;
  }

  function normalizeMethod(rawMethod) {
    const value = String(rawMethod || "").trim().toUpperCase();
    return value === "POST" ? "POST" : "GET";
  }

  function resolveUrl(urlOverride) {
    const explicit = String(urlOverride == null ? "" : urlOverride).trim();
    if (explicit) {
      return explicit;
    }
    return String(this.url || "").trim();
  }

  function resolveData(dataOverride) {
    if (typeof dataOverride !== "undefined") {
      return this.normalizePayload(dataOverride);
    }
    return this.normalizePayload(this.data);
  }

  function appendQueryParams(baseUrl, payload) {
    const target = String(baseUrl || "").trim();
    if (!target) {
      return "";
    }
    if (typeof payload === "string") {
      const text = String(payload || "").trim();
      if (!text) {
        return target;
      }
      if (text.indexOf("=") !== -1) {
        return target + (target.indexOf("?") === -1 ? "?" : "&") + text.replace(/^\?/, "");
      }
      return target;
    }
    if (!payload || typeof payload !== "object" || Array.isArray(payload)) {
      return target;
    }
    const query = new URLSearchParams();
    const keys = Object.keys(payload);
    for (let i = 0; i < keys.length; i += 1) {
      const key = String(keys[i] || "").trim();
      if (!key) {
        continue;
      }
      const value = payload[key];
      if (typeof value === "undefined") {
        continue;
      }
      if (Array.isArray(value)) {
        for (let j = 0; j < value.length; j += 1) {
          query.append(key, value[j] == null ? "" : String(value[j]));
        }
        continue;
      }
      query.append(key, value == null ? "" : String(value));
    }
    const encoded = query.toString();
    if (!encoded) {
      return target;
    }
    return target + (target.indexOf("?") === -1 ? "?" : "&") + encoded;
  }

  function parseResponsePayload(response) {
    if (!response || typeof response !== "object") {
      return Promise.resolve({ result: "" });
    }
    const contentType = response.headers && typeof response.headers.get === "function"
      ? String(response.headers.get("content-type") || "").toLowerCase()
      : "";
    if (contentType.indexOf("application/json") !== -1 && typeof response.json === "function") {
      return response.json().catch(() => ({ result: "" }));
    }
    if (typeof response.text === "function") {
      return response.text().then((text) => {
        const raw = String(text || "");
        if (!raw.trim()) {
          return { result: "" };
        }
        try {
          return JSON.parse(raw);
        } catch (error) {
          return { result: raw };
        }
      });
    }
    return Promise.resolve({ result: "" });
  }

  function get(urlOverride, dataOverride, init) {
    this.ensureComponentBridge();
    const targetUrl = this.resolveUrl(urlOverride);
    if (!targetUrl) {
      const missingUrlError = new Error("sdml-object.get requires a non-empty url.");
      this.error("", missingUrlError);
      return Promise.reject(missingUrlError);
    }
    const payload = this.resolveData(dataOverride);
    const finalUrl = this.appendQueryParams(targetUrl, payload);
    this.request(finalUrl, "GET", payload);
    if (typeof fetch !== "function") {
      const missingFetchError = new Error("sdml-object.get requires fetch() support.");
      this.error(finalUrl, missingFetchError);
      return Promise.reject(missingFetchError);
    }
    return fetch(finalUrl, Object.assign({}, init || {}, { method: "GET" }))
      .then((response) => this.parseResponsePayload(response))
      .then((body) => {
        this.response(finalUrl, body);
        return body;
      })
      .catch((error) => {
        this.error(finalUrl, error);
        throw error;
      });
  }

  function post(urlOverride, dataOverride, init) {
    this.ensureComponentBridge();
    const targetUrl = this.resolveUrl(urlOverride);
    if (!targetUrl) {
      const missingUrlError = new Error("sdml-object.post requires a non-empty url.");
      this.error("", missingUrlError);
      return Promise.reject(missingUrlError);
    }
    const payload = this.resolveData(dataOverride);
    if (typeof fetch !== "function") {
      const missingFetchError = new Error("sdml-object.post requires fetch() support.");
      this.error(targetUrl, missingFetchError);
      return Promise.reject(missingFetchError);
    }
    const requestInit = Object.assign({}, init || {}, { method: "POST" });
    if (typeof payload !== "undefined" && payload !== null) {
      const isFormData = typeof FormData !== "undefined" && payload instanceof FormData;
      const isUrlSearchParams = typeof URLSearchParams !== "undefined" && payload instanceof URLSearchParams;
      const isBlob = typeof Blob !== "undefined" && payload instanceof Blob;
      if (!isFormData && !isUrlSearchParams && !isBlob && typeof payload === "object") {
        requestInit.headers = Object.assign({}, requestInit.headers || {}, { "Content-Type": "application/json" });
        requestInit.body = JSON.stringify(payload);
      } else {
        requestInit.body = payload;
      }
    }
    this.request(targetUrl, "POST", payload);
    return fetch(targetUrl, requestInit)
      .then((response) => this.parseResponsePayload(response))
      .then((body) => {
        this.response(targetUrl, body);
        return body;
      })
      .catch((error) => {
        this.error(targetUrl, error);
        throw error;
      });
  }

  function send(urlOverride, dataOverride, init) {
    this.ensureComponentBridge();
    const selectedMethod = this.normalizeMethod(this.method);
    if (selectedMethod === "POST") {
      return this.post(urlOverride, dataOverride, init);
    }
    return this.get(urlOverride, dataOverride, init);
  }

  onReady {
    this.ensureComponentBridge();
  }
}
