 div.q-popup-container {
 slot { popup-contents }
 }
 }
}

q-component q-popup-menu extends q-popup-floating-div {
function uuidv4() {
  return "10000000-1000-4000-8000-100000000000".replace(/[018]/g, c =>
    (+c ^ crypto.getRandomValues(new Uint8Array(1))[0] & 15 >> +c / 4).toString(16)
  );
}

 function show(x,y) { this.component.style.display = "block"; this.component.style.left = x; this.component.style.top = y; this.component.classList.add("visible");
  this.component.classList.add("q-popup-menu-open");
  if (String(this.component.getAttribute("id")) == "") { this.component.setAttribute("id", this.component.uuidv4()) }
  var popup = this.component;
 document.addEventListener("click", function(e) {
    popup.hide()
    }, { once: true })
  }
  function hide() { this.component.style.display = "none"; this.component.classList.remove("visible"); }
}


/* implementation is
q-popup-menu myMenu {
  id: "my-menu"
  popup-contents {
    ul {
      li { text { hello world } }
      li { text { hello world } }
      hr { }
      li { text { hello world } }
    }
  }
}


div { oncontextmenu { myMenu.show(event.clientX, event.clientY); console.log("Context menu opened at", event.pageX, event.pageY, event) } }
*/

q-component q-resizable-item {
  q-property { width height }

  function numberOr(value, fallback) {
    var n = Number(value);
    if (!Number.isFinite(n)) {
      return Number(fallback);
    }
    return n;
  }

  function minWidth() {
    return 64;
  }

  function minHeight() {
    return 44;
  }

  function afterResize(width, height) {
    return { width: width, height: height };
  }

  function applySize(rawWidth, rawHeight) {
    var nextWidth = Math.max(this.minWidth(), Math.round(this.numberOr(rawWidth, this.width == null ? 320 : this.width)));
    var nextHeight = Math.max(this.minHeight(), Math.round(this.numberOr(rawHeight, this.height == null ? 56 : this.height)));

    this.width = nextWidth;
    this.height = nextHeight;

    if (this.style) {
      this.style.width = String(nextWidth) + "px";
      this.style.height = String(nextHeight) + "px";
      this.style.boxSizing = "border-box";
    }

    this.afterResize(nextWidth, nextHeight);
    return { width: nextWidth, height: nextHeight };
  }

  function resizeHandle() {
    return this.querySelector("[q-resize-handle='1']") || this;
  }

  function handleResizeStart(event) {
    if (!event || (event.button != null && event.button !== 0)) {
      return;
    }

    var rect = this.getBoundingClientRect ? this.getBoundingClientRect() : { width: this.width || 320, height: this.height || 56 };
    this.__resizeState = {
      mouseX: Number(event.clientX || 0),
      mouseY: Number(event.clientY || 0),
      startWidth: Number(rect.width || this.width || 320),
      startHeight: Number(rect.height || this.height || 56)
    };

    var win = this.ownerDocument && this.ownerDocument.defaultView ? this.ownerDocument.defaultView : window;
    if (!this.__resizeMoveHandler) {
      var host = this;
      this.__resizeMoveHandler = function(moveEvent) {
        if (!host.__resizeState) {
          return;
        }
        var dx = Number(moveEvent.clientX || 0) - host.__resizeState.mouseX;
        var dy = Number(moveEvent.clientY || 0) - host.__resizeState.mouseY;
        host.applySize(host.__resizeState.startWidth + dx, host.__resizeState.startHeight + dy);
      };
    }

    if (!this.__resizeEndHandler) {
      var hostEnd = this;
      this.__resizeEndHandler = function() {
        hostEnd.__resizeState = null;
        win.removeEventListener("mousemove", hostEnd.__resizeMoveHandler);
        win.removeEventListener("mouseup", hostEnd.__resizeEndHandler);
      };
    }

    win.addEventListener("mousemove", this.__resizeMoveHandler);
    win.addEventListener("mouseup", this.__resizeEndHandler);

    if (typeof event.preventDefault === "function") {
      event.preventDefault();
    }
  }

  function setupResizing() {
    if (this.__resizeReady) {
      return;
    }
    this.__resizeReady = true;

    var handle = this.resizeHandle();
    if (!handle || typeof handle.addEventListener !== "function") {
      return;
    }

    var host = this;
    this.__resizeStartHandler = function(event) {
      host.handleResizeStart(event);
    };

    handle.addEventListener("mousedown", this.__resizeStartHandler);
  }

  onReady {
    this.setupResizing();
    this.applySize(this.width, this.height);
  }
}

q-style q-sidebar-panel-style {
  backgroundColor: rgb(230, 238, 249)
  color: #0f172a
  borderColor: #c7d8ef
}
q-style q-sidebar-toggle-style {
  q-style-class { w3-button }
  backgroundColor: rgb(203, 213, 225)
  color: #0f172a
  borderColor: #94a3b8
}
q-default-theme q-sidebar-theme {
  .q-sidebar-panel { q-sidebar-panel-style }
  .q-sidebar-toggle { q-sidebar-toggle-style }
}

q-component q-sidebar {

  q-property open: "1"
  q-property sidebarWidth: "260"
  q-property collapsedWidth: "2vw"

  function normalizeOpenValue(rawValue) {
    var value = String(rawValue == null ? "" : rawValue).toLowerCase().trim();
    if (value === "0" || value === "false" || value === "off" || value === "closed" || value === "hide" || value === "hidden") {
      return "0";
    }
    return "1";
  }

  function currentOpenValue() {
    return this.normalizeOpenValue(this.open == null ? "1" : this.open);
  }

  function expandedWidthPx() {
    var value = Number(this.sidebarWidth);
    if (!Number.isFinite(value) || value < 120) {
      value = 260;
    }
    return Math.floor(value);
  }

  function collapsedWidthValue() {
    var value = String(this.collapsedWidth || "2vw").trim();
    if (!value) {
      value = "2vw";
    }
    return value;
  }

  function sidebarTrackForMode(mode) {
    if (String(mode) === "1") {
      return this.expandedWidthPx() + "px";
    }
    return "max(" + this.collapsedWidthValue() + ", 24px)";
  }

  function applyOpenMode(nextOpenValue) {
    var mode = this.normalizeOpenValue(nextOpenValue);
    this.open = mode;

    if (this.classList && typeof this.classList.add === "function") {
      this.classList.remove("q-sidebar-open");
      this.classList.remove("q-sidebar-closed");
      this.classList.add(mode === "1" ? "q-sidebar-open" : "q-sidebar-closed");
    }

    var layout = this.querySelector("[q-sidebar-layout='1']");
    var panel = this.querySelector("[q-sidebar-panel='1']");
    var button = this.querySelector("[q-sidebar-toggle='1']");
    var indicator = this.querySelector("[q-sidebar-indicator='1']");
    var track = this.sidebarTrackForMode(mode);

    if (layout && layout.style) {
      layout.style.gridTemplateColumns = track + " minmax(0, 1fr)";
    }
    if (panel && panel.style) {
      panel.style.opacity = mode === "1" ? "1" : "0.6";
    }
    if (button && button.style) {
      button.style.left = "calc(" + track + " - 16px)";
    }
    if (indicator) {
      indicator.innerHTML = mode === "1" ? "&#10094;" : "&#9776;";
    }
    return mode;
  }

  function show() {
    return this.applyOpenMode("1");
  }

  function hide() {
    return this.applyOpenMode("0");
  }

  function toggle() {
    return this.applyOpenMode(this.currentOpenValue() === "1" ? "0" : "1");
  }

  onReady {
    if (this.__qSidebarReady) {
      return;
    }
    this.__qSidebarReady = true;
    this.applyOpenMode(this.currentOpenValue());
  }

  q-sidebar-theme {
    div {
      q-sidebar-root: "1"
      style { position: relative; min-height: 1px; height: 100%; overflow: hidden; }
      div {
        q-sidebar-layout: "1"
        style {
          display: grid;
          grid-template-columns: 260px minmax(0, 1fr);
          height: 100%;
          min-height: 1px;
          transition: grid-template-columns 220ms ease;
        }
        aside.q-sidebar-panel {
          q-sidebar-panel: "1"
          style {
            min-width: 0;
            overflow: hidden;
            border-right: 1px solid transparent;
            transition: opacity 140ms ease;
          }
          slot { content }
        }
        div {
          q-sidebar-main: "1"
          style { min-width: 0; overflow: auto; }
          slot { main }
        }
      }

      button.q-sidebar-toggle {
        q-sidebar-toggle: "1"
        type: "button"
        style {
          position: absolute;
          top: 8px;
          left: calc(260px - 16px);
          z-index: 1002;
          border-radius: 6px;
          transition: left 220ms ease;
          padding: 4px 10px;
        }
        onclick {
          var host = this.closest ? this.closest("q-sidebar") : null;
          if (!host && this.component) {
            host = this.component.closest ? this.component.closest("q-sidebar") : this.component;
          }
          if (host && typeof host.toggle === "function") {
            host.toggle();
          }
        }
        span {
          q-sidebar-indicator: "1"
          html { &#10094; }
        }
      }
    }
  }
}

q-component q-spritesheet {
  q-signal frameChanged(frameIndex)

  q-property source: ""
  q-property frameCount: 1
  q-property frameStart: 0
  q-property frameStop: 0
  q-property frameDuration: 120
  q-property frameWidth: 0
  q-property frameHeight: 0
  q-property currentFrame: 0
  q-property repeat: true
  q-property running: false
  q-property interpolate: false
  q-property columns: 0
  q-property rows: 0
  q-property imageWidth: 0
  q-property imageHeight: 0
  q-property loaded: false

  div.q-spritesheet-viewport#q-spritesheet-viewport { }

  q-timer frameTimer {
    interval: 120
    repeat: true
    running: false
  }

  q-connect { frameTimer.timeout this.component.nextFrame }

  function normalizePositiveInt(value, fallbackValue) {
    var numeric = Number(value);
    if (!Number.isFinite(numeric) || numeric <= 0) {
      return Math.max(1, Math.floor(Number(fallbackValue || 1)));
    }
    return Math.max(1, Math.floor(numeric));
  }

  function normalizeBoolean(value, fallbackValue) {
    if (value === true || value === false) {
      return value;
    }
    if (value === 1 || value === "1") {
      return true;
    }
    if (value === 0 || value === "0") {
      return false;
    }
    var text = String(value == null ? "" : value).trim().toLowerCase();
    if (text === "true" || text === "yes" || text === "on") {
      return true;
    }
    if (text === "false" || text === "no" || text === "off" || text === "") {
      return false;
    }
    return Boolean(fallbackValue);
  }

  function resolveFrameStart() {
    var count = this.component.normalizePositiveInt(this.component.frameCount, 1);
    var start = Math.floor(Number(this.component.frameStart || 0));
    if (!Number.isFinite(start) || start < 0) {
      start = 0;
    }
    if (start > (count - 1)) {
      start = count - 1;
    }
    return start;
  }

  function resolveFrameStop() {
    var count = this.component.normalizePositiveInt(this.component.frameCount, 1);
    var start = this.component.resolveFrameStart();
    var maxStop = Math.max(start, count - 1);
    var stop = Math.floor(Number(this.component.frameStop || 0));
    if (!Number.isFinite(stop) || stop < start || stop > maxStop) {
      stop = maxStop;
    }
    return stop;
  }

  function clampFrame(value) {
    var start = this.component.resolveFrameStart();
    var stop = this.component.resolveFrameStop();
    var frame = Math.floor(Number(value || 0));
    if (!Number.isFinite(frame)) {
      frame = start;
    }
    if (frame < start) {
      frame = start;
    }
    if (frame > stop) {
      frame = stop;
    }
    return frame;
  }

  function configureGeometry() {
    var count = this.component.normalizePositiveInt(this.component.frameCount, 1);
    var imgWidth = Math.max(0, Math.floor(Number(this.component.imageWidth || 0)));
    var imgHeight = Math.max(0, Math.floor(Number(this.component.imageHeight || 0)));

    var currentFrameWidth = Math.floor(Number(this.component.frameWidth));
    var autoFrameWidth = !Number.isFinite(currentFrameWidth) || currentFrameWidth <= 0;
    var nextFrameWidth = autoFrameWidth ? 0 : currentFrameWidth;
    if (autoFrameWidth && imgWidth > 0 && count > 0) {
      nextFrameWidth = Math.floor(imgWidth / count);
    }
    nextFrameWidth = this.component.normalizePositiveInt(nextFrameWidth, 1);

    var currentFrameHeight = Math.floor(Number(this.component.frameHeight));
    var autoFrameHeight = !Number.isFinite(currentFrameHeight) || currentFrameHeight <= 0;
    var nextFrameHeight = autoFrameHeight ? 0 : currentFrameHeight;
    if (autoFrameHeight && imgHeight > 0) {
      nextFrameHeight = imgHeight;
    }
    nextFrameHeight = this.component.normalizePositiveInt(nextFrameHeight, 1);

    if ((!autoFrameWidth || imgWidth > 0) && Number(this.component.frameWidth) !== nextFrameWidth) {
      this.component.frameWidth = nextFrameWidth;
    }
    if ((!autoFrameHeight || imgHeight > 0) && Number(this.component.frameHeight) !== nextFrameHeight) {
      this.component.frameHeight = nextFrameHeight;
    }

    var derivedColumns = count;
    if (imgWidth > 0 && nextFrameWidth > 0) {
      derivedColumns = Math.max(1, Math.floor(imgWidth / nextFrameWidth));
    }
    var derivedRows = 1;
    if (imgHeight > 0 && nextFrameHeight > 0) {
      derivedRows = Math.max(1, Math.floor(imgHeight / nextFrameHeight));
    }

    if (Number(this.component.columns || 0) !== derivedColumns) {
      this.component.columns = derivedColumns;
    }
    if (Number(this.component.rows || 0) !== derivedRows) {
      this.component.rows = derivedRows;
    }
  }

  function applyFrameToViewport() {
    var viewport = this.querySelector("#q-spritesheet-viewport");
    if (!viewport) {
      return;
    }
    var frameWidth = this.component.normalizePositiveInt(this.component.frameWidth, 1);
    var frameHeight = this.component.normalizePositiveInt(this.component.frameHeight, 1);
    var frame = this.component.clampFrame(this.component.currentFrame);
    if (frame !== Number(this.component.currentFrame || 0)) {
      this.component.currentFrame = frame;
      return;
    }

    viewport.style.display = "inline-block";
    viewport.style.position = "relative";
    viewport.style.overflow = "hidden";
    viewport.style.width = String(frameWidth) + "px";
    viewport.style.height = String(frameHeight) + "px";
    viewport.style.backgroundRepeat = "no-repeat";
    viewport.style.backgroundImage = this.component.source ? ("url(\"" + String(this.component.source) + "\")") : "none";
    viewport.style.transition = this.component.normalizeBoolean(this.component.interpolate, false) ? "background-position 120ms linear" : "none";
    viewport.style.backgroundPosition = String(-frame * frameWidth) + "px 0px";

    this.component.frameChanged(frame);
  }

  function refreshTimer() {
    var duration = Math.max(0, Math.floor(Number(this.component.frameDuration || 0)));
    frameTimer.interval = duration;
    if (this.component.normalizeBoolean(this.component.running, false) && this.component.loaded === true) {
      frameTimer.start();
      return;
    }
    frameTimer.stop();
  }

  function syncSource() {
    var src = String(this.component.source || "").trim();
    this.component.loaded = false;
    this.component.imageWidth = 0;
    this.component.imageHeight = 0;
    if (!src) {
      this.component.configureGeometry();
      this.component.applyFrameToViewport();
      this.component.refreshTimer();
      return;
    }
    var image = new Image();
    image.onload = function onSpriteSourceLoaded() {
      this.component.imageWidth = Math.max(0, Math.floor(Number(image.width || 0)));
      this.component.imageHeight = Math.max(0, Math.floor(Number(image.height || 0)));
      this.component.loaded = true;
      this.component.configureGeometry();
      this.component.applyFrameToViewport();
      this.component.refreshTimer();
    }.bind(this);
    image.onerror = function onSpriteSourceError() {
      this.component.loaded = false;
      this.component.configureGeometry();
      this.component.applyFrameToViewport();
      this.component.refreshTimer();
    }.bind(this);
    image.src = src;
  }

  function nextFrame() {
    if (this.component.loaded !== true) {
      return;
    }
    var start = this.component.resolveFrameStart();
    var stop = this.component.resolveFrameStop();
    var current = this.component.clampFrame(this.component.currentFrame);
    var next = current + 1;
    if (next > stop) {
      if (this.component.normalizeBoolean(this.component.repeat, true)) {
        next = start;
      } else {
        next = stop;
        this.component.running = false;
      }
    }
    this.component.currentFrame = next;
  }

  function start() {
    this.component.running = true;
  }

  function stop() {
    this.component.running = false;
  }

  onready {
    this.component.configureGeometry();
    this.component.applyFrameToViewport();
    this.component.syncSource();
  }

  onsourcechanged {
    this.component.syncSource();
  }

  onframeCountchanged {
    this.component.configureGeometry();
    this.component.applyFrameToViewport();
  }

  onframeWidthchanged {
    this.component.configureGeometry();
    this.component.applyFrameToViewport();
  }

  onframeHeightchanged {
    this.component.configureGeometry();
    this.component.applyFrameToViewport();
  }

  onframeStartchanged {
    this.component.applyFrameToViewport();
  }

  onframeStopchanged {
    this.component.applyFrameToViewport();
  }

  onframeDurationchanged {
    this.component.refreshTimer();
  }

  onrunningchanged {
    this.component.refreshTimer();
  }

  oninterpolatechanged {
    this.component.applyFrameToViewport();
  }

  oncurrentFramechanged {
    this.component.applyFrameToViewport();
  }
}

q-rewrite q-tab-panel-rewriter {
  slot { main }
  return {
    q-script {
      var body = String(this.slot("main") || "").trim();
      if (!body) {
        body = "html { &nbsp; }";
      }
      return "div.q-tab-panel { q-tab-panel: \"1\" " + body + " }";
    }
  }
}

q-component q-tab {
  function getTabsContainer() {
    return this.closest ? this.closest("q-tabs") : null;
  }

  function getLabel() {
    const attrLabel = String(this.getAttribute("name") || this.getAttribute("label") || "").trim();
    if (attrLabel) {
      return attrLabel;
    }
    const labelNode = this.querySelector("[q-tab-name='1']");
    const text = labelNode ? String(labelNode.textContent || "").trim() : "";
    return text || "Tab";
  }

  function show() {
    const tabsHost = this.getTabsContainer();
    if (tabsHost && typeof tabsHost.showTab === "function") {
      tabsHost.showTab(this);
      return this;
    }
    this.style.display = "block";
    this.setAttribute("q-tab-active", "1");
    return this;
  }

  function hide() {
    this.style.display = "none";
    this.setAttribute("q-tab-active", "0");
    return this;
  }

  onReady {
    if (this.getTabsContainer()) {
      this.hide();
    }
  }

  div {
    q-tab-name: "1"
    style { display: none; }
    slot { name }
  }

  q-tab-panel-rewriter {
    main { slot { content } }
  }
}

q-component q-tabs {
q-style q-tab-panel-style {
  q-style-class { w3-container }
  backgroundColor: rgba(255, 255, 255, 0.55)
  color: inherit
  border: 1px solid #d7e2f1
  borderRadius: 8px
  marginTop: 0.35rem
  padding: 0.6rem 0.7rem
}
q-style q-tabs-container-style {
  q-style-class { w3-container w3-round-large w3-border }
  backgroundColor: #eef3fb
  color: #0f172a
  borderColor: #c7d8ef
  padding: 0
  overflow: hidden
}
q-style q-tabs-nav-style {
  q-style-class { w3-bar }
  backgroundColor: #dde8f7
  borderBottom: 1px solid #c7d8ef
  display: flex
  gap: 0.25rem
  padding: 0.25rem
}
q-style q-tabs-content-style {
  q-style-class { w3-animate-opacity }
  backgroundColor: #f6f9fe
  color: #0f172a
  borderColor: #d7e2f1
  minHeight: 5rem
  padding: 0.65rem
}
q-default-theme q-tabs-theme {
  .q-tab-panel { q-tab-panel-style }
  .q-tabs-container { q-tabs-container-style }
  .q-tabs-nav { q-tabs-nav-style }
  .q-tabs-content-themed { q-tabs-content-style }
}
q-property navActiveButtonClass: ""
q-property navInactiveButtonClass: ""
q-property containerClass: ""
q-alias containerclass { return this.component.containerClass }
q-alias navinactivebuttonclass { return this.component.navInactiveButtonClass }
q-alias navactivebuttonclass { return this.component.navActiveButtonClass }

  function applyNavButtonStyle(button, isActive) {
    if (!button || !button.style) {
      return;
    }
    var active = !!isActive;
    button.style.backgroundColor = active ? "#1d4ed8" : "#e2e8f0";
    button.style.color = active ? "#ffffff" : "#0f172a";
    button.style.border = "1px solid " + (active ? "#1e40af" : "#c7d8ef");
    button.style.borderRadius = "6px";
    button.style.padding = "0.42rem 0.72rem";
    button.style.lineHeight = "1.1";
    button.style.transition = "background-color 140ms ease, color 140ms ease, border-color 140ms ease";
    button.style.boxShadow = active
      ? "0 1px 0 rgba(15, 23, 42, 0.12)"
      : "none";
  }

  function createSignalEvent(payload) {
    if (typeof CustomEvent === "function") {
      return new CustomEvent("q-signal", {
        detail: payload,
        bubbles: true,
      });
    }
    return null;
  }

  function emitSignal(signalName, detail) {
    const payload = {
      component: "q-tabs",
      signal: String(signalName || "").trim(),
      detail: detail || {},
    };

    const signalEvent = this.createSignalEvent(payload);
    if (signalEvent) {
      this.dispatchEvent(signalEvent);
    }

    if (typeof CustomEvent === "function" && payload.signal) {
      this.dispatchEvent(new CustomEvent("q-tabs:" + payload.signal, {
        detail: payload,
        bubbles: true,
      }));
    }
  }

  function getNavBar() {
    return this.querySelector("[q-tabs-nav='1']");
  }

  function getContentRoot() {
    return this.querySelector("[q-tabs-content='1']") || this;
  }

  function isOwnedByThisTabs(tabNode) {
    if (!tabNode || typeof tabNode !== "object") {
      return false;
    }

    let current = tabNode.parentElement;
    while (current) {
      if (current === this) {
        return true;
      }
      if (current.tagName && String(current.tagName).toLowerCase() === "q-tabs") {
        return false;
      }
      current = current.parentElement;
    }

    return false;
  }

  function collectTabs() {
    const root = this.getContentRoot();
    const all = Array.from(root.querySelectorAll("q-tab"));
    const tabs = all.filter((node) => this.isOwnedByThisTabs(node));
    this.tabs = tabs;
    for (let i = 0; i < tabs.length; i += 1) {
      tabs[i].setAttribute("q-tab-index", String(i));
    }
    return tabs;
  }

  function getTabLabel(tabNode, index) {
    if (tabNode && typeof tabNode.getLabel === "function") {
      const text = String(tabNode.getLabel() || "").trim();
      if (text) {
        return text;
      }
    }
    return "Tab " + (index + 1);
  }

  function classTokens(value) {
    return String(value || "")
      .split(/\s+/)
      .map((token) => token.trim())
      .filter(Boolean);
  }

  function normalizeTabSelection(tabOrIndex, tabs) {
    const list = Array.isArray(tabs) ? tabs : [];
    if (!list.length) {
      return null;
    }

    if (typeof tabOrIndex === "number" && Number.isFinite(tabOrIndex)) {
      const idx = Math.max(0, Math.min(list.length - 1, Math.floor(tabOrIndex)));
      return list[idx];
    }

    if (typeof tabOrIndex === "string") {
      const raw = String(tabOrIndex).trim();
      if (!raw) {
        return null;
      }
      const asNumber = Number(raw);
      if (Number.isFinite(asNumber)) {
        return this.normalizeTabSelection(asNumber, list);
      }
      for (let i = 0; i < list.length; i += 1) {
        const label = this.getTabLabel(list[i], i);
        if (label === raw) {
          return list[i];
        }
      }
      const byId = this.querySelector("#" + raw);
      if (byId && list.indexOf(byId) !== -1) {
        return byId;
      }
      return null;
    }

    if (tabOrIndex && typeof tabOrIndex === "object" && list.indexOf(tabOrIndex) !== -1) {
      return tabOrIndex;
    }

    return null;
  }

  function getRootHost() {
    if (typeof this.root === "function") {
      const root = this.root();
      if (root && root.nodeType === 1) {
        return root;
      }
    }
    return this.closest ? this.closest("q-html") : null;
  }

  function normalizeTabLabel(label, indexHint) {
    const text = String(label == null ? "" : label).trim();
    if (text) {
      return text;
    }
    const idx = Number.isFinite(Number(indexHint)) ? Number(indexHint) : 0;
    return "Tab " + String(idx + 1);
  }

  function cloneQDomNode(node) {
    if (!node || typeof node !== "object") {
      return null;
    }
    try {
      return JSON.parse(JSON.stringify(node));
    } catch (err) {
      return node;
    }
  }

  function resolveQDomNodeFromHtmlNode(domNode) {
    if (!domNode || typeof domNode !== "object" || typeof domNode.nodeType !== "number") {
      return null;
    }
    if (typeof domNode.qdom === "function") {
      try {
        const direct = domNode.qdom();
        if (direct && typeof direct === "object") {
          return direct;
        }
      } catch (err) { }
    }
    const host = this.getRootHost();
    if (!host || typeof host.uuidFor !== "function" || typeof host.qdomForUuid !== "function") {
      return null;
    }
    const uuid = String(host.uuidFor(domNode) || "").trim();
    if (!uuid) {
      return null;
    }
    const mapped = host.qdomForUuid(uuid);
    return mapped && typeof mapped === "object" ? mapped : null;
  }

  function normalizeTabContentNodes(input) {
    if (input == null) {
      return [];
    }

    if (typeof input === "string") {
      const host = this.getRootHost();
      const rootQdom = host && typeof host.qdom === "function" ? host.qdom() : null;
      if (!rootQdom || typeof rootQdom.createInstanceFromQHTML !== "function") {
        return [];
      }
      const parsed = rootQdom.createInstanceFromQHTML(input);
      return this.normalizeTabContentNodes(parsed);
    }

    if (Array.isArray(input)) {
      const out = [];
      for (let i = 0; i < input.length; i += 1) {
        const nextNodes = this.normalizeTabContentNodes(input[i]);
        for (let j = 0; j < nextNodes.length; j += 1) {
          out.push(nextNodes[j]);
        }
      }
      return out;
    }

    if (input && typeof input === "object" && typeof input.nodeType === "number") {
      if (input.nodeType === 3) {
        const tabsQdom = typeof this.qdom === "function" ? this.qdom() : null;
        if (tabsQdom && typeof tabsQdom.createQText === "function") {
          return [tabsQdom.createQText(String(input.textContent || ""))];
        }
        return [];
      }
      const mapped = this.resolveQDomNodeFromHtmlNode(input);
      return this.normalizeTabContentNodes(mapped);
    }

    if (input && typeof input === "object") {
      const kind = String(input.kind || "").trim().toLowerCase();
      if (kind === "document" && Array.isArray(input.nodes)) {
        return this.normalizeTabContentNodes(input.nodes);
      }
      const cloned = this.cloneQDomNode(input);
      return cloned && typeof cloned === "object" ? [cloned] : [];
    }

    return [];
  }

  function addTab(label, input) {
    const tabsQdom = typeof this.qdom === "function" ? this.qdom() : null;
    if (!tabsQdom || typeof tabsQdom.createQComponentInstance !== "function" || typeof tabsQdom.appendNode !== "function") {
      return null;
    }

    const existing = this.collectTabs();
    const nextIndex = Array.isArray(existing) ? existing.length : 0;
    const tabLabel = this.normalizeTabLabel(label, nextIndex);

    const tabNode = tabsQdom.createQComponentInstance("q-tab", {
      name: tabLabel,
    });
    if (!tabNode || typeof tabNode.appendNode !== "function" || typeof tabNode.createQSlot !== "function") {
      return null;
    }

    const contentNodes = this.normalizeTabContentNodes(input);
    if (contentNodes.length > 0) {
      tabNode.appendNode(tabNode.createQSlot("content", contentNodes));
    } else {
      const fallback = tabNode.createQElement("div", {}, [tabNode.createQText(" ")]);
      tabNode.appendNode(tabNode.createQSlot("content", [fallback]));
    }

    tabsQdom.appendNode(tabNode);

    const host = this.getRootHost();
    const tabsUuid = String((tabsQdom && tabsQdom.UUID) || "").trim();
    if (host && typeof host.update === "function") {
      if (tabsUuid) {
        host.update(tabsUuid);
      } else {
        host.update();
      }
    }

    const liveTabs = host && this.id ? host.querySelector("#" + this.id) || this : this;
    if (liveTabs && typeof liveTabs.refreshTabs === "function") {
      const refreshed = liveTabs.refreshTabs();
      const index = Array.isArray(refreshed) ? Math.max(0, refreshed.length - 1) : nextIndex;
      if (typeof liveTabs.showTab === "function") {
        liveTabs.showTab(index);
      }
    }

    return tabNode;
  }

  function buildNav(tabs) {
    const nav = this.getNavBar();
    if (!nav) {
      return;
    }

    nav.innerHTML = "";
    const list = Array.isArray(tabs) ? tabs : [];

    for (let i = 0; i < list.length; i += 1) {
      const tab = list[i];
      const button = document.createElement("button");
      button.type = "button";
      button.className = "w3-bar-item w3-btn q-tab-link";
      button.setAttribute("q-tab-link-index", String(i));
      button.textContent = this.getTabLabel(tab, i);
      button.onclick = () => this.showTab(tab);
      this.applyNavButtonStyle(button, false);
      nav.appendChild(button);
      tab.__qTabsButton = button;
    }
  }

  function applyActiveState(tabs, activeIndex) {
    const list = Array.isArray(tabs) ? tabs : [];
    const activeTokens = this.classTokens(this.component.navActiveButtonClass);
    const inactiveTokens = this.classTokens(this.component.navInactiveButtonClass);
    for (let i = 0; i < list.length; i += 1) {
      const tab = list[i];
      const isActive = i === activeIndex;
      tab.style.display = isActive ? "block" : "none";
      tab.setAttribute("q-tab-active", isActive ? "1" : "0");

      const button = tab.__qTabsButton;
      if (button && button.classList) {
        for (let j = 0; j < activeTokens.length; j += 1) {
          button.classList.remove(activeTokens[j]);
        }
        for (let j = 0; j < inactiveTokens.length; j += 1) {
          button.classList.remove(inactiveTokens[j]);
        }
        if (isActive) {
          for (let j = 0; j < activeTokens.length; j += 1) {
            button.classList.add(activeTokens[j]);
          }
        } else {
          for (let j = 0; j < inactiveTokens.length; j += 1) {
            button.classList.add(inactiveTokens[j]);
          }
        }
        if (activeTokens.length > 0 || inactiveTokens.length > 0) {
          button.style.backgroundColor = "";
          button.style.color = "";
          button.style.border = "";
          button.style.boxShadow = "";
          button.style.borderRadius = "6px";
          button.style.padding = "0.42rem 0.72rem";
          button.style.lineHeight = "1.1";
          button.style.transition = "background-color 140ms ease, color 140ms ease, border-color 140ms ease";
        } else {
          this.applyNavButtonStyle(button, isActive);
        }
      }
    }
  }

  function showTab(tabOrIndex) {
    const tabs = this.collectTabs();
    if (!tabs.length) {
      this.activeTab = null;
      return null;
    }

    const target = this.normalizeTabSelection(tabOrIndex, tabs) || tabs[0];
    const activeIndex = tabs.indexOf(target);

    this.applyActiveState(tabs, activeIndex);
    this.activeTab = target;
    this.setAttribute("q-tabs-active-index", String(activeIndex));

    this.emitSignal("tab-shown", {
      index: activeIndex,
      tabName: this.getTabLabel(target, activeIndex),
    });

    return target;
  }

  function hideAllTabs() {
    const tabs = this.collectTabs();
    this.applyActiveState(tabs, -1);
    this.activeTab = null;
    this.setAttribute("q-tabs-active-index", "-1");
    this.emitSignal("tabs-hidden", {
      count: tabs.length,
    });
    return tabs;
  }

  function refreshTabs() {
    const tabs = this.collectTabs();
    this.buildNav(tabs);
    if (!tabs.length) {
      this.activeTab = null;
      this.setAttribute("q-tabs-active-index", "-1");
      return [];
    }

    const preferred = this.getAttribute("q-tabs-active-index");
    const initial = this.normalizeTabSelection(preferred, tabs) || this.activeTab || tabs[0];
    this.showTab(initial);
    return tabs;
  }

  onReady {
    const self = this;
    setTimeout(function() {
      try {
        self.refreshTabs();
      } catch (err) {
        console.error("q-tabs refresh failed", err);
      }
    }, 0);
  }

  q-tabs-theme {
    div.q-tabs-container {
      div.q-tabs-nav{
        q-tabs-nav: "1"
      }

      div.q-tabs-content-themed.q-tabs-content {
        onReady {
          var tokens = this.component.classTokens(this.component.containerClass);
          for (var i = 0; i < tokens.length; i += 1) {
            this.classList.add(tokens[i]);
          }
        }
        q-tabs-content: "1"
        slot { content }
      }
    }
  }
}

q-painter q-tech-panel-painter {
  q-property borderWidth: "5px"
  q-property borderColor: "white"
  q-property shadowColor: "green"
  q-property topLeft: "0px 0px"
  q-property topRight: "0px 0px"
  q-property bottomRight: "0px 0px"
  q-property bottomLeft: "0px 0px"
  q-property patternShift: "0px 0px"
  q-property patternSize: "20px"
  q-property topDent: "10px"
  q-property topDentLength: "10%"
  q-property percentage: "0.5"
  q-property backgroundSeed: "117"
  q-property backgroundImage: ""
  q-property backgroundSize: "cover"
  q-property backgroundPosition: "center"
  q-property backgroundRepeat: "no-repeat"

  onpaint {
    function isNumericStart(value) {
      var text = String(value == null ? "" : value).trim();
      var first = text.charAt(0);
      return (first >= "0" && first <= "9") || first === "-" || first === ".";
    }

    function normalizeCssValue(value, maxValue, fallback) {
      var text = String(value == null ? "" : value).trim();
      if (!text) {
        return fallback;
      }
      if (!isNumericStart(text)) {
        return text;
      }
      if (text.charAt(text.length - 1) === "%" && maxValue != null) {
        var pct = Number.parseFloat(text.slice(0, -1));
        return Number.isFinite(pct) ? (pct / 100) * maxValue : fallback;
      }
      var parsed = Number.parseFloat(text);
      return Number.isFinite(parsed) ? parsed : fallback;
    }

    function normalizePair(value, maxV, maxH) {
      var text = String(value == null ? "" : value).trim();
      if (!text) {
        return { v: 0, h: 0 };
      }
      var parts = text.split(/\s+/).filter(Boolean);
      if (parts.length === 1) {
        return {
          v: normalizeCssValue(parts[0], maxV, 0),
          h: normalizeCssValue(parts[0], maxH, 0)
        };
      }
      return {
        v: normalizeCssValue(parts[0], maxV, 0),
        h: normalizeCssValue(parts[1], maxH, 0)
      };
    }

    function asNumber(value, fallback) {
      var parsed = Number(value);
      return Number.isFinite(parsed) ? parsed : fallback;
    }

    function clamp(value, min, max) {
      return Math.max(min, Math.min(max, value));
    }

    function buildBorderPath(width, height, cfg) {
      var offset = cfg.offset || 0;
      var topLeft = cfg.topLeft;
      var topRight = cfg.topRight;
      var bottomRight = cfg.bottomRight;
      var bottomLeft = cfg.bottomLeft;
      var topDent = Math.max(0, cfg.topDent || 0);
      var topDentLength = Math.max(0, cfg.topDentLength || 0);
      var path = new Path2D();
      var topStartX = offset + topLeft.h;
      var topEndX = width - offset - topRight.h;
      var topY = offset;

      path.moveTo(offset, offset + topLeft.v);
      if (topLeft.h !== 0 || topLeft.v !== 0) {
        path.lineTo(topStartX, topY);
      } else {
        path.lineTo(offset, topY);
      }

      var topSpan = Math.max(0, topEndX - topStartX);
      if (topDent > 0 && topDentLength > 0 && topSpan > 0) {
        var dentLength = Math.min(topDentLength, topSpan);
        var slope = Math.min(topDent, Math.max(0, (topSpan - dentLength) / 2));
        var side = Math.max(0, (topSpan - dentLength - (2 * slope)) / 2);
        var x1 = topStartX + side;
        path.lineTo(x1, topY);
        path.lineTo(x1 + slope, topY + topDent);
        path.lineTo(x1 + slope + dentLength, topY + topDent);
        path.lineTo(x1 + (2 * slope) + dentLength, topY);
      }

      path.lineTo(topEndX, topY);
      if (topRight.h !== 0 || topRight.v !== 0) {
        path.lineTo(width - offset, offset + topRight.v);
      }

      path.lineTo(width - offset, height - offset - bottomRight.v);
      if (bottomRight.h !== 0 || bottomRight.v !== 0) {
        path.lineTo(width - offset - bottomRight.h, height - offset);
      }

      path.lineTo(offset + bottomLeft.h, height - offset);
      if (bottomLeft.h !== 0 || bottomLeft.v !== 0) {
        path.lineTo(offset, height - offset - bottomLeft.v);
      }

      path.closePath();
      return path;
    }

    function drawHexagon(ctx, hexSize, start) {
      var ang = Math.sin(Math.PI / 3);
      ctx.moveTo(start.x, start.y);
      ctx.lineTo(start.x + hexSize, start.y);
      ctx.lineTo(start.x + hexSize + (hexSize * ang), start.y + (1.5 * hexSize * ang));
      ctx.lineTo(start.x + hexSize, start.y + (3 * hexSize * ang));
      ctx.lineTo(start.x, start.y + (3 * hexSize * ang));
      ctx.lineTo(start.x - (hexSize * ang), start.y + (1.5 * hexSize * ang));
      ctx.closePath();
    }

    function drawHexaGrid(ctx, width, height, hexSize, shift) {
      if (!Number.isFinite(hexSize) || hexSize <= 0) {
        return;
      }
      var ang = Math.sin(Math.PI / 3);
      var rowHeight = Math.max(1, 3 * ang * hexSize);
      var colWidth = Math.max(1, hexSize + (hexSize * ang));
      var rows = Math.ceil(height / rowHeight) + 3;
      var cols = Math.ceil(width / colWidth) + 3;
      for (var row = -1; row < rows; row += 1) {
        for (var col = -1; col < cols; col += 1) {
          drawHexagon(ctx, hexSize, {
            x: (col * colWidth) + shift.h,
            y: (row * rowHeight) + (col % 2 ? 0 : 1.5 * hexSize * ang) + shift.v
          });
        }
      }
    }

    function createRng(seed) {
      var state = Number(seed);
      if (!Number.isFinite(state)) {
        state = 117;
      }
      state = state >>> 0;
      return {
        next: function() {
          state = ((1664525 * state) + 1013904223) >>> 0;
          return state / 4294967296;
        },
        range: function(min, max) {
          return min + ((max - min) * this.next());
        },
        int: function(min, max) {
          return Math.floor(this.range(min, max + 1));
        }
      };
    }

    function roundedPath(ctx, x, y, w, h, r) {
      var rr = Math.min(r, w / 2, h / 2);
      ctx.beginPath();
      ctx.moveTo(x + rr, y);
      ctx.lineTo(x + w - rr, y);
      ctx.quadraticCurveTo(x + w, y, x + w, y + rr);
      ctx.lineTo(x + w, y + h - rr);
      ctx.quadraticCurveTo(x + w, y + h, x + w - rr, y + h);
      ctx.lineTo(x + rr, y + h);
      ctx.quadraticCurveTo(x, y + h, x, y + h - rr);
      ctx.lineTo(x, y + rr);
      ctx.quadraticCurveTo(x, y, x + rr, y);
      ctx.closePath();
    }

    function metalStroke(ctx, pathFn, width, color, shadowBlur, shadowColor) {
      ctx.save();
      ctx.lineJoin = "round";
      ctx.lineCap = "round";
      ctx.lineWidth = width;
      ctx.strokeStyle = color;
      ctx.shadowBlur = shadowBlur || 0;
      ctx.shadowColor = shadowColor || "transparent";
      pathFn();
      ctx.stroke();
      ctx.restore();
    }

    function drawBrushedLines(ctx, rng, x, y, w, h, count, alpha, mostlyHorizontal) {
      ctx.save();
      ctx.lineWidth = 1;
      for (var i = 0; i < count; i += 1) {
        var sx = rng.range(x, x + w);
        var sy = rng.range(y, y + h);
        var len = rng.range(8, mostlyHorizontal ? 90 : 48);
        var angle = mostlyHorizontal ? rng.range(-0.04, 0.04) : rng.range(-0.95, 0.95);
        ctx.strokeStyle = rng.next() > 0.5 ? "rgba(255,255,255," + (alpha * rng.range(0.15, 1)) + ")" : "rgba(0,0,0," + (alpha * rng.range(0.25, 1.4)) + ")";
        ctx.beginPath();
        ctx.moveTo(sx, sy);
        ctx.lineTo(sx + (Math.cos(angle) * len), sy + (Math.sin(angle) * len));
        ctx.stroke();
      }
      ctx.restore();
    }

    function drawCloudyMetal(ctx, rng, x, y, w, h) {
      for (var i = 0; i < 64; i += 1) {
        var rx = rng.range(x, x + w);
        var ry = rng.range(y, y + h);
        var r = rng.range(18, 95);
        var a = rng.range(0.018, 0.075);
        var g = ctx.createRadialGradient(rx, ry, 0, rx, ry, r);
        g.addColorStop(0, rng.next() > 0.55 ? "rgba(255,255,255," + a + ")" : "rgba(0,0,0," + (a * 1.5) + ")");
        g.addColorStop(1, "rgba(0,0,0,0)");
        ctx.fillStyle = g;
        ctx.beginPath();
        ctx.ellipse(rx, ry, r * rng.range(0.8, 1.7), r * rng.range(0.25, 0.75), rng.range(-0.7, 0.7), 0, Math.PI * 2);
        ctx.fill();
      }
    }

    function drawPit(ctx, rng, x, y, r) {
      ctx.save();
      var g = ctx.createRadialGradient(x - (r * 0.2), y - (r * 0.4), 0, x, y, r * 2.1);
      g.addColorStop(0, "rgba(255,255,255,.25)");
      g.addColorStop(0.35, "rgba(0,0,0,.55)");
      g.addColorStop(1, "rgba(0,0,0,0)");
