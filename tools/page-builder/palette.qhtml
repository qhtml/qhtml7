    details {
      padding: "12px 0"
      summary {
        cursor: "pointer"
        fontWeight: "800"
        slot faqTwoQuestion { text { Does this export clean QHTML? } }
      }
      p {
        color: "#64748b"
        lineHeight: "1.55"
        slot faqTwoAnswer { text { The builder keeps the structure editable and serializes the final QHTML. } }
      }
    }
  }
}

