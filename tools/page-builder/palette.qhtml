q-component pageBuilderPalette {
  aside.page-builder-palette {
    header.page-builder-palette-header {
      h2 { text { Palette } }
      p { text { Choose a component definition. Drag and drop wiring comes next. } }
    }

    q-layout {
      width: "inherit"
      height: "85vh"
      gap: "8px"

      q-col {
        width: "inherit"
        height: "inherit"

        section.page-builder-palette-group {
          h3 { text { Sections } }
          builderPaletteButton decoratedHeadlinePaletteButton {
            paletteId: "builder.decorated-headline"
            definitionName: "builderDecoratedHeadline"
            definitionUUID: "builder-definition-decorated-headline"
            displayName: "Decorated Headline"
            category: "Headers"
            description: "Eyebrow, headline, divider"
            iconLabel: "T"
            instanceName: "decoratedHeadline"
            slotNames: "headlineEyebrow,headlineText,headlineSubtext"
            function instantiatePaletteItem() { return this.createInstanceFromType(builderDecoratedHeadlinePaletteItem); }
          }
          builderPaletteButton heroPaletteButton {
            paletteId: "builder.hero"
            definitionName: "builderHeroBlock"
            definitionUUID: "builder-definition-hero"
            displayName: "Hero"
            category: "Sections"
            description: "Headline, copy, and actions"
            iconLabel: "H"
            instanceName: "heroBlock"
            slotNames: "heroTitle,heroSubtitle,heroActions,heroContent"
            function instantiatePaletteItem() { return this.createInstanceFromType(builderHeroPaletteItem); }
          }
          builderPaletteButton calloutPaletteButton {
            paletteId: "builder.callout"
            definitionName: "builderCalloutBlock"
            definitionUUID: "builder-definition-callout"
            displayName: "Callout"
            category: "Sections"
            description: "Highlighted message"
            iconLabel: "!"
            instanceName: "calloutBlock"
            slotNames: "calloutLabel,calloutBody,calloutContent"
            function instantiatePaletteItem() { return this.createInstanceFromType(builderCalloutPaletteItem); }
          }
          builderPaletteButton statsBandPaletteButton {
            paletteId: "builder.stats-band"
            definitionName: "builderStatsBand"
            definitionUUID: "builder-definition-stats-band"
            displayName: "Stats Band"
            category: "Trust"
            description: "Three compact metrics"
            iconLabel: "3"
            instanceName: "statsBand"
            slotNames: "statOneValue,statOneLabel,statTwoValue,statTwoLabel,statThreeValue,statThreeLabel"
            function instantiatePaletteItem() { return this.createInstanceFromType(builderStatsBandPaletteItem); }
          }
        }

        section.page-builder-palette-group {
          h3 { text { Layout And Content } }
          builderPaletteButton twoColumnPaletteButton {
            paletteId: "builder.two-column"
            definitionName: "builderTwoColumnBlock"
            definitionUUID: "builder-definition-two-column"
            displayName: "Two Column"
            category: "Layouts"
            description: "Left and right areas"
            iconLabel: "2"
            instanceName: "twoColumnBlock"
            slotNames: "leftTitle,leftBody,rightTitle,rightBody"
            function instantiatePaletteItem() { return this.createInstanceFromType(builderTwoColumnPaletteItem); }
          }
          builderPaletteButton featureCardPaletteButton {
            paletteId: "builder.feature-card"
            definitionName: "builderFeatureCard"
            definitionUUID: "builder-definition-feature-card"
            displayName: "Feature Card"
            category: "Cards"
            description: "Icon, title, and body"
            iconLabel: "C"
            instanceName: "featureCard"
            slotNames: "featureIcon,featureTitle,featureBody,featureContent"
            function instantiatePaletteItem() { return this.createInstanceFromType(builderFeatureCardPaletteItem); }
          }
          builderPaletteButton htmlPaletteButton {
            paletteId: "builder.html"
            definitionName: "builderHtmlBlock"
            definitionUUID: "builder-definition-html"
            displayName: "HTML Block"
            category: "Content"
            description: "Raw HTML area"
            iconLabel: "<>"
