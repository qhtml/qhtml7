q-component builderFormBlock {
  form.builder-form-block {
    action: "#"
    method: "post"
    backgroundColor: "#ffffff"
    padding: "24px"
    borderRadius: "14px"
    borderWidth: "1px"
    borderColor: "#dbe4f0"
    slot formContents {
      div.form-field {
        label { text { Name } }
        input {
          type: "text"
          name: "name"
          placeholder: "Your name"
        }
      }
      div.form-field {
        label { text { Email } }
        input {
          type: "email"
          name: "email"
          placeholder: "you@example.com"
        }
      }
      div.form-actions {
        button {
          type: "submit"
          text { Send Message }
        }
      }
    }
  }
}

