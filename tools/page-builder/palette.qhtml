q-component builderHeroBlock {
  section.builder-hero-block {
    backgroundColor: "#ffffff"
    color: "#0f172a"
    padding: "48px"
    borderRadius: "18px"
    borderWidth: "1px"
    borderColor: "#dbe4f0"
    boxShadow: "0 18px 50px rgba(15,23,42,.10)"
    h1 {
      margin: "0 0 14px"
      fontSize: "44px"
      lineHeight: "1"
      fontWeight: "900"
      slot heroTitle { text { Launch faster } }
    }
    p {
      margin: "0 0 22px"
      color: "#475569"
      fontSize: "18px"
      lineHeight: "1.55"
      slot heroSubtitle { text { Compose QHTML pages visually. } }
    }
    div.builder-actions {
      display: "flex"
      flexWrap: "wrap"
      gap: "10px"
      marginBottom: "18px"
      slot heroActions { button { text { Get started } } }
    }
    div.builder-content-slot { slot heroContent { text { Add supporting content. } } }
  }
}

q-component builderFeatureCard {
  article.builder-feature-card {
    backgroundColor: "#ffffff"
    color: "#0f172a"
    padding: "24px"
    borderRadius: "14px"
    borderWidth: "1px"
    borderColor: "#dbe4f0"
    boxShadow: "0 12px 32px rgba(15,23,42,.08)"
    span.builder-feature-icon {
      display: "inline-grid"
      width: "38px"
      height: "38px"
      marginBottom: "14px"
      borderRadius: "10px"
      backgroundColor: "#eff6ff"
      color: "#1d4ed8"
      fontWeight: "900"
      slot featureIcon { text { * } }
    }
    h3 {
      margin: "0 0 8px"
      fontSize: "20px"
      slot featureTitle { text { Feature title } }
    }
    p {
      margin: "0"
      color: "#64748b"
      lineHeight: "1.55"
      slot featureBody { text { Explain the benefit clearly. } }
    }
    div.builder-content-slot { slot featureContent { text { Add nested content. } } }
  }
}

q-component builderTwoColumnBlock {
  section.builder-two-column-block {
    backgroundColor: "#ffffff"
