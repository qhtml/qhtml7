q-component page-builder-toolbar {
  function exportLayout() {
    window.QPageBuilder.exportToPanel();
  }

  function clearLayout() {
    window.QPageBuilder.clearCanvas();
  }

  function newFile() {
    window.QPageBuilder.newLayoutFile();
  }

  function saveLayout() {
    window.QPageBuilder.saveLayout();
  }

  function loadLayout() {
    window.QPageBuilder.loadLayout();
  }

  function fileManager() {
    window.QPageBuilder.openFileManager();
  }

  function importQHtml() {
    window.QPageBuilder.importQHtmlFile();
  }

  function exportFolder() {
    window.QPageBuilder.exportFolder();
  }

  header.pb-toolbar {
    div.pb-brand {
      div.pb-logo { text { Q } }
      div {
        h1 { text { QHTML Page Builder } }
        p { text { Drag palette items into the canvas. Export emits clean QHTML layout source. } }
      }
    }
    div.pb-actions {
      button.pb-action.secondary {
        type: "button"
        onclick { this.closest("page-builder-toolbar").newFile(); }
        text { New }
      }
      button.pb-action.secondary {
        type: "button"
        onclick { this.closest("page-builder-toolbar").saveLayout(); }
        text { Save }
      }
      button.pb-action.secondary {
        type: "button"
        onclick { this.closest("page-builder-toolbar").loadLayout(); }
        text { Load }
      }
      button.pb-action.secondary {
        type: "button"
        onclick { this.closest("page-builder-toolbar").fileManager(); }
        text { File Manager }
      }
      button.pb-action.secondary {
        type: "button"
        onclick { this.closest("page-builder-toolbar").importQHtml(); }
        text { Import QHTML }
      }
      button.pb-action.danger {
        type: "button"
        onclick { this.closest("page-builder-toolbar").clearLayout(); }
        text { Clear }
      }
      button.pb-action.primary {
        type: "button"
        onclick { this.closest("page-builder-toolbar").exportLayout(); }
        text { Export QHTML }
      }
      button.pb-action.primary {
        type: "button"
        onclick { this.closest("page-builder-toolbar").exportFolder(); }
        text { Export Folder }
      }
    }
  }
}

q-component page-builder-palette {
  aside.pb-sidebar {
    div.pb-sidebar-head {
      h2 { text { Palette } }
      p { text { Drag blocks onto the canvas. Items can be moved after they are dropped. } }
    }

    q-palette-toolbox {
      docked: "true"
      title: "Blocks"

      q-palette-toolbox-button {
        name: "New"
        component: "pb-new-component"
        data-pb-create-component: "true"
        div.pb-palette-preview.new-component {
          h3 { text { New } }
          p { text { q-component } }
        }
      }

      q-palette-toolbox-button {
        name: "Heading"
        component: "pb-heading-block"
        qhtml: "q-style pbHeadingBlockHeaderStyle { padding: 20px; borderRadius: 18px; background: #ffffff; border: 1px solid #dbe4f0; color: #0f172a } q-style pbHeadingBlockTitleStyle { margin: 0; fontSize: 30px; letterSpacing: -.04em; color: #0f172a } q-style pbHeadingBlockSubtitleStyle { marginTop: 8px; color: #64748b; lineHeight: 1.5 } q-theme pbHeadingBlockTheme { header { pbHeadingBlockHeaderStyle } h2 { pbHeadingBlockTitleStyle } p { pbHeadingBlockSubtitleStyle } } pbHeadingBlockTheme { header { h2 { q-layout { data-pb-slot: \"headingTitle\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { headingTitle } } } } } p { q-layout { data-pb-slot: \"headingSubtitle\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { headingSubtitle } } } } } q-layout { data-pb-slot: \"headingContent\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { headingContent } } } } } } q-slot-default headingTitle { text { Your heading here } } q-slot-default headingSubtitle { text { Add a short supporting subtitle for this section. } } q-slot-default headingContent { text { Add supporting content or nested blocks here. } }"
        instance: "pb-heading-block { }"
        div.pb-palette-preview.heading {
          h3 { text { Heading } }
          p { text { Title and subtitle } }
        }
      }

      q-palette-toolbox-button {
        name: "Hero"
        component: "pb-hero-block"
        qhtml: "q-style pbHeroBlockSectionStyle { padding: 32px; borderRadius: 20px; background: linear-gradient(135deg,#0f172a,#1d4ed8); color: white } q-style pbHeroBlockTitleStyle { margin: 0; fontSize: 38px; letterSpacing: -.06em } q-style pbHeroBlockCopyStyle { maxWidth: 560px; color: #dbeafe; lineHeight: 1.5 } q-style pbHeroBlockButtonStyle { border: 0; borderRadius: 999px; background: #22d3ee; color: #0f172a; fontWeight: 900; padding: 10px 16px } q-theme pbHeroBlockTheme { section.pb-hero-block { pbHeroBlockSectionStyle } h1 { pbHeroBlockTitleStyle } p { pbHeroBlockCopyStyle } button { pbHeroBlockButtonStyle } } pbHeroBlockTheme { section.pb-hero-block { h1 { q-layout { data-pb-slot: \"heroTitle\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { heroTitle } } } } } p { q-layout { data-pb-slot: \"heroSubtitle\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { heroSubtitle } } } } } button { class: \"pb-demo-button\" q-layout { data-pb-slot: \"heroButtonText\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { heroButtonText } } } } } q-layout { data-pb-slot: \"heroContent\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { heroContent } } } } } } q-slot-default heroTitle { text { Launch Faster } } q-slot-default heroSubtitle { text { Compose a clean landing page visually, then export declarative QHTML. } } q-slot-default heroButtonText { text { Start Building } } q-slot-default heroContent { text { Add hero details or nested blocks here. } }"
        instance: "pb-hero-block { }"
        div.pb-palette-preview.hero {
          h3 { text { Hero } }
          p { text { Headline, copy, CTA } }
        }
      }

      q-palette-toolbox-button {
        name: "Card"
        component: "pb-card-block"
        qhtml: "q-style pbCardBlockArticleStyle { padding: 22px; borderRadius: 18px; background: #f8fafc; border: 1px solid #dbe4f0; color: #0f172a; boxShadow: 0 12px 28px rgba(15,23,42,.08) } q-style pbCardBlockTitleStyle { marginTop: 0; marginBottom: 8px; color: #0f172a } q-style pbCardBlockBodyStyle { color: #475569; lineHeight: 1.5 } q-theme pbCardBlockTheme { article.pb-feature-card { pbCardBlockArticleStyle } h3 { pbCardBlockTitleStyle } p { pbCardBlockBodyStyle } } pbCardBlockTheme { article.pb-feature-card { h3 { q-layout { data-pb-slot: \"cardTitle\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { cardTitle } } } } } p { q-layout { data-pb-slot: \"cardBody\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { cardBody } } } } } q-layout { data-pb-slot: \"cardContent\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { cardContent } } } } } } q-slot-default cardTitle { text { Card title } } q-slot-default cardBody { text { Use this card for compact page content or feature summaries. } } q-slot-default cardContent { text { Add card details or nested blocks here. } }"
        instance: "pb-card-block { }"
        div.pb-palette-preview.card {
          h3 { text { Card } }
          p { text { Title and body } }
        }
      }

      q-palette-toolbox-button {
        name: "Callout"
        component: "pb-callout"
        qhtml: "q-style pbCalloutAsideStyle { padding: 18px; borderRadius: 18px; background: #fffbeb; border: 1px solid #fde68a; color: #78350f } q-style pbCalloutStrongStyle { display: block; marginBottom: 6px; fontWeight: 900 } q-style pbCalloutBodyStyle { margin: 0; color: #78350f; lineHeight: 1.5 } q-theme pbCalloutTheme { aside.pb-callout { pbCalloutAsideStyle } strong { pbCalloutStrongStyle } p { pbCalloutBodyStyle } } pbCalloutTheme { aside.pb-callout { strong { q-layout { data-pb-slot: \"calloutLabel\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { calloutLabel } } } } } p { q-layout { data-pb-slot: \"calloutBody\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { calloutBody } } } } } q-layout { data-pb-slot: \"calloutContent\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { calloutContent } } } } } } q-slot-default calloutLabel { text { Note } } q-slot-default calloutBody { text { Use callouts for announcements, warnings, or highlighted copy. } } q-slot-default calloutContent { text { Add supporting details here. } }"
