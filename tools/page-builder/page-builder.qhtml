  }
}

q-component page-builder-canvas {
  section.pb-canvas-shell {
    div.pb-canvas-meta {
      div {
        h2 { text { Layout Canvas } }
        p { text { Drop blocks where they belong. Red indicators show insert position. } }
      }
      div.pb-status { id: "pb-builder-status"; text { Ready } }
    }

    div.pb-stage {
      q-layout {
        id: "pb-builder-layout";
        width: "100%";
        gap: "14px";
      }
    }
  }
}

q-component page-builder-export-panel {
  section.pb-export-panel {
    div.pb-export-head {
      h2 { text { Exported QHTML } }
      p { text { The export includes q-component definitions for palette items used in the layout, followed by the generated layout tree. } }
    }
    q-editor {
      id: "pb-export-output"
    }
  }
}

q-component page-builder-component-builder {
  dialog.pb-component-builder {
    id: "pb-component-builder"
    div.pb-component-builder-card {
      header.pb-component-builder-head {
        div {
          h2 { text { New q-component } }
          p { id: "pb-component-builder-subtitle"; text { Create a palette component for this page. } }
        }
        button.pb-icon-button {
          type: "button"
          aria-label: "Close component builder"
          onclick { window.QPageBuilder.closeComponentBuilder(); }
          html { &times; }
        }
      }

      nav.pb-component-builder-tabs {
        button.active {
          type: "button"
          data-pb-builder-tab: "general"
          onclick { window.QPageBuilder.switchComponentBuilderTab("general"); }
          text { General }
        }
        button {
          type: "button"
          data-pb-builder-tab: "structure"
          onclick { window.QPageBuilder.switchComponentBuilderTab("structure"); }
          text { Structure }
        }
        button {
          type: "button"
          data-pb-builder-tab: "handlers"
          onclick { window.QPageBuilder.switchComponentBuilderTab("handlers"); }
          text { Handlers }
        }
        button {
          type: "button"
          data-pb-builder-tab: "animation"
          onclick { window.QPageBuilder.switchComponentBuilderTab("animation"); }
          text { Animation }
        }
        button {
          type: "button"
          data-pb-builder-tab: "preview"
          onclick { window.QPageBuilder.switchComponentBuilderTab("preview"); }
          text { Preview }
        }
      }

      section.pb-component-builder-panel {
        data-pb-builder-panel: "general"
        div.pb-component-general-grid {
          label {
            text { q-component name }
            input {
              id: "pb-component-builder-name"
              type: "text"
              value: "my-component"
              inputmode: "text"
              onchange { window.QPageBuilder.updateComponentBuilderGeneral(); }
              oninput { window.QPageBuilder.updateComponentBuilderGeneral(); }
            }
          }
          label {
            text { extends }
            input {
              id: "pb-component-builder-extends"
              type: "text"
              placeholder: "base-card base-panel"
              inputmode: "text"
              onchange { window.QPageBuilder.updateComponentBuilderGeneral(); }
              oninput { window.QPageBuilder.updateComponentBuilderGeneral(); }
            }
          }
        }
      }

      section.pb-component-builder-panel {
        data-pb-builder-panel: "structure"
        hidden: "hidden"
        div.pb-component-builder-workbench {
          div.pb-component-builder-tools {
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("tag"); } text { tag } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("q-signal"); } text { q-signal } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("slot"); } html { slot } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("function"); } text { function } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("q-property"); } text { q-property } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("q-var"); } text { q-var } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("q-layout"); } text { q-layout } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("q-row"); } text { q-row } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("q-col"); } text { q-col } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("q-connect"); } text { q-connect } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("html"); } text { HTML } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("text"); } text { text } }
            button { type: "button"; onclick { window.QPageBuilder.indentComponentBuilderEditor(); } text { Indent } }
            button { type: "button"; onclick { window.QPageBuilder.outdentComponentBuilderEditor(); } text { Outdent } }
          }
          q-editor {
            id: "pb-component-builder-structure"
          }
        }
      }

      section.pb-component-builder-panel {
        data-pb-builder-panel: "handlers"
        hidden: "hidden"
        div.pb-component-builder-workbench {
          div.pb-component-builder-tools {
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("onclick"); } text { onclick } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("onready"); } text { onready } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("onpaint"); } text { onpaint } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("on-signal"); } text { on<signal> } }
            button { type: "button"; onclick { window.QPageBuilder.insertComponentBuilderSnippet("on-property-changed"); } text { on<property>changed } }
            button { type: "button"; onclick { window.QPageBuilder.indentComponentBuilderEditor(); } text { Indent } }
            button { type: "button"; onclick { window.QPageBuilder.outdentComponentBuilderEditor(); } text { Outdent } }
          }
          q-editor {
            id: "pb-component-builder-handlers"
          }
        }
      }

      section.pb-component-builder-panel {
        data-pb-builder-panel: "preview"
        hidden: "hidden"
        div.pb-component-builder-preview {
          q-editor {
            id: "pb-component-builder-preview"
          }
        }
      }

      section.pb-component-builder-panel {
        data-pb-builder-panel: "animation"
        hidden: "hidden"
        div.pb-component-animation-panel {
          p { text { Generate animation boilerplate for this component. The dialog targets this.component and scans current q-property declarations. } }
          button.pb-action.primary {
            type: "button"
            onclick { window.QPageBuilder.openComponentBuilderAnimationTool(); }
            text { Open Animation Tool }
          }
          q-animation-tool {
            id: "pb-component-animation-tool"
          }
        }
      }

      div.pb-component-builder-error {
        id: "pb-component-builder-error"
      }

      footer.pb-component-builder-actions {
        button.pb-action.secondary {
          type: "button"
          onclick { window.QPageBuilder.closeComponentBuilder(); }
          text { Cancel }
        }
        button.pb-action.primary {
          type: "button"
          onclick { window.QPageBuilder.createComponentBuilderItem(); }
          text { Create }
        }
      }
    }
  }
}

q-component page-builder-palette-editor {
  dialog.pb-palette-editor {
    id: "pb-palette-editor"
    div.pb-palette-editor-card {
      header.pb-palette-editor-head {
        div {
          h2 { text { Edit Palette Component } }
          p { id: "pb-palette-editor-subtitle"; text { Update the QHTML source used by this palette item. } }
        }
        button.pb-icon-button {
          type: "button"
          aria-label: "Close editor"
          onclick { window.QPageBuilder.closePaletteEditor(); }
          html { &times; }
        }
      }
      input {
        id: "pb-palette-editor-component"
        type: "hidden"
      }
      div.pb-editor-label {
        text { QHTML Source }
      }
      q-editor {
        id: "pb-palette-editor-source"
      }
      div.pb-palette-editor-error {
        id: "pb-palette-editor-error"
      }
      footer.pb-palette-editor-actions {
        button.pb-action.secondary {
          type: "button"
          onclick { window.QPageBuilder.closePaletteEditor(); }
          text { Cancel }
        }
        button.pb-action.primary {
          type: "button"
          onclick { window.QPageBuilder.savePaletteEdit(); }
          text { Save Component }
        }
      }
    }
  }
}

q-component page-builder-instance-editor {
  dialog.pb-instance-editor {
    id: "pb-instance-editor"
    div.pb-instance-editor-card {
      header.pb-instance-editor-head {
        div {
          h2 { text { Edit QHTML Instance } }
          p { id: "pb-instance-editor-subtitle"; text { Select an instance and edit one of its slots. } }
        }
        button.pb-icon-button {
          type: "button"
          aria-label: "Close instance editor"
          onclick { window.QPageBuilder.closeInstanceEditor(); }
          html { &times; }
        }
      }

      div.pb-instance-controls {
        label {
          id: "pb-instance-editor-instance-row"
          text { Instance }
          select {
            id: "pb-instance-editor-instance"
            onchange { window.QPageBuilder.selectInstanceEditTarget(this.value); }
          }
        }
        label {
          id: "pb-instance-editor-slot-row"
          text { Slot }
          select {
            id: "pb-instance-editor-slot"
            onchange { window.QPageBuilder.selectInstanceEditSlot(this.value); }
          }
        }
      }

      div.pb-instance-editor-body {
        q-editor {
          id: "pb-instance-editor-source"
        }
      }

      div.pb-instance-editor-error {
        id: "pb-instance-editor-error"
      }

      footer.pb-instance-editor-actions {
        button.pb-action.secondary {
          type: "button"
          onclick { window.QPageBuilder.closeInstanceEditor(); }
          text { Close }
        }
        button.pb-action.primary {
          type: "button"
          onclick { window.QPageBuilder.saveInstanceEdit(); }
          text { Save Instance }
        }
      }
    }
  }
}

q-component page-builder-file-dialog {
  dialog.pb-file-dialog {
    id: "pb-file-dialog"
    div.pb-file-card {
      header.pb-file-head {
        div {
          h2 { text { Site Files } }
          p { id: "pb-file-dialog-subtitle"; text { Select a file to load, or organize pages into folders. } }
        }
        button.pb-icon-button {
          type: "button"
          aria-label: "Close files"
          onclick { window.QPageBuilder.closeFileDialog(); }
          html { &times; }
        }
      }

      div.pb-file-toolbar {
        button.pb-action.secondary {
          type: "button"
          onclick { window.QPageBuilder.newFileFolder(); }
          text { New folder }
        }
        button.pb-action.secondary {
          type: "button"
          onclick { window.QPageBuilder.newFile(); }
          text { New file }
        }
      }

      div.pb-file-body {
        q-tree-view {
          id: "pb-file-tree"
        }
      }

      footer.pb-file-actions {
        div.pb-file-selected {
          id: "pb-file-selected"
          text { / }
        }
        button.pb-action.secondary {
          type: "button"
          onclick { window.QPageBuilder.closeFileDialog(); }
          text { Close }
        }
      }
    }
  }
}

q-component page-builder-file-manager {
  dialog.pb-file-dialog {
    id: "pb-file-manager"
    div.pb-file-card {
      header.pb-file-head {
        div {
          h2 { text { File Manager } }
          p { id: "pb-file-manager-subtitle"; text { Select a file to rename, delete, or move. } }
        }
        button.pb-icon-button {
          type: "button"
          aria-label: "Close file manager"
          onclick { window.QPageBuilder.closeFileManager(); }
          html { &times; }
        }
      }

      div.pb-file-body {
        q-tree-view {
          id: "pb-file-manager-tree"
        }
      }

      footer.pb-file-actions {
        div.pb-file-selected {
          id: "pb-file-manager-selected"
          text { / }
        }
        button.pb-action.secondary {
          type: "button"
          onclick { window.QPageBuilder.renameManagedFile(); }
          text { Rename }
        }
        button.pb-action.secondary {
          type: "button"
          onclick { window.QPageBuilder.moveManagedFile(); }
          text { Move }
        }
        button.pb-action.danger {
          type: "button"
          onclick { window.QPageBuilder.deleteManagedFile(); }
          text { Delete }
        }
        button.pb-action.secondary {
          type: "button"
          onclick { window.QPageBuilder.closeFileManager(); }
          text { Close }
        }
      }
    }
  }
}

q-component page-builder-folder-picker {
  dialog.pb-file-dialog {
    id: "pb-folder-picker"
    div.pb-file-card {
      header.pb-file-head {
        div {
          h2 {
            id: "pb-folder-picker-title"
            text { Select Folder }
          }
          p {
            id: "pb-folder-picker-subtitle"
            text { Choose a destination folder. }
          }
        }
        button.pb-icon-button {
          type: "button"
          aria-label: "Close folder picker"
          onclick { window.QPageBuilder.closeFolderPicker(); }
          html { &times; }
        }
      }

      div.pb-file-body {
        q-tree-view {
          id: "pb-folder-tree"
          foldersOnly: true
        }
      }

      footer.pb-file-actions {
        div.pb-file-selected {
          id: "pb-folder-selected"
          text { / }
        }
        button.pb-action.secondary {
          type: "button"
          onclick { window.QPageBuilder.closeFolderPicker(); }
          text { Cancel }
        }
        button.pb-action.primary {
          type: "button"
          onclick { window.QPageBuilder.confirmFolderPicker(); }
          text { Choose Folder }
        }
      }
    }
  }
}

q-component page-builder-app {
  q-style pageBuilderAppStyle {
    minHeight: 100vh;
    display: grid;
    gridTemplateRows: auto minmax(0,1fr);
    background: rgba(15,23,42,.92);
    color: #172033;
    fontFamily: "Aptos, Segoe UI, sans-serif";
  }

  q-style pageBuilderToolbarStyle {
    height: 78px;
    display: flex;
    alignItems: center;
    justifyContent: space-between;
    padding: 0 24px;
    background: rgba(255,255,255,.86);
    backdropFilter: blur(18px);
    borderBottom: 1px solid rgba(148,163,184,.38);
    boxShadow: 0 14px 48px rgba(15,23,42,.08);
    position: sticky;
    top: 0;
    zIndex: 50;
  }

  q-style pageBuilderBrandStyle {
    display: flex;
    alignItems: center;
    gap: 14px;
  }

  q-style pageBuilderLogoStyle {
    width: 44px;
    height: 44px;
    borderRadius: 16px;
    display: grid;
    placeItems: center;
    background: linear-gradient(135deg,#0f172a,#2563eb);
    color: white;
    fontWeight: 950;
    fontSize: 22px;
    boxShadow: 0 12px 28px rgba(37,99,235,.28);
  }

  q-style pageBuilderTitleStyle {
    fontSize: 22px;
    lineHeight: 1;
    margin: 0;
    letterSpacing: -.04em;
  }

  q-style pageBuilderCopyStyle {
    margin: .35rem 0 0;
    color: #607089;
    fontSize: 13px;
    lineHeight: 1.4;
  }

  q-style pageBuilderActionRowStyle {
    display: flex;
    gap: 10px;
    flexWrap: wrap;
  }

  q-style pageBuilderActionStyle {
    border: 0;
    borderRadius: 999px;
    padding: 10px 15px;
    fontWeight: 800;
    cursor: pointer;
    boxShadow: 0 8px 22px rgba(15,23,42,.08);
  }

  q-style pageBuilderPrimaryActionStyle {
    background: #0f172a;
    color: white;
  }

  q-style pageBuilderSecondaryActionStyle {
    background: white;
    color: #1d4ed8;
    border: 1px solid #c7d2fe;
  }

  q-style pageBuilderDangerActionStyle {
    background: #fff1f2;
    color: #be123c;
    border: 1px solid #fecdd3;
  }

  q-style pageBuilderWorkspaceStyle {
    minHeight: 0;
    display: grid;
    gridTemplateColumns: 300px minmax(0,1fr);
    gap: 18px;
    padding: 18px;
  }

  q-style pageBuilderMainStyle {
    minWidth: 0;
    display: grid;
    gridTemplateRows: minmax(0,1fr) 260px;
    gap: 18px;
  }

  q-style pageBuilderSidebarStyle {
    minHeight: 0;
    background: rgba(15,23,42,.92);
    border: 1px solid rgba(148,163,184,.24);
    borderRadius: 26px;
    boxShadow: 0 28px 80px rgba(15,23,42,.22);
    overflow: hidden;
    color: white;
  }

  q-style pageBuilderSidebarHeadStyle {
    padding: 22px 22px 10px;
  }

  q-style pageBuilderPanelStyle {
    background: rgba(255,255,255,.78);
    border: 1px solid rgba(148,163,184,.42);
    borderRadius: 26px;
    boxShadow: 0 22px 70px rgba(15,23,42,.12);
    overflow: hidden;
  }

  q-style pageBuilderPanelHeadStyle {
    display: flex;
    justifyContent: space-between;
    alignItems: center;
    padding: 18px 20px;
    borderBottom: 1px solid rgba(148,163,184,.28);
    background: rgba(248,250,252,.82);
  }

  q-style pageBuilderSectionTitleStyle {
    margin: 0;
    fontSize: 18px;
    letterSpacing: -.03em;
  }

  q-style pageBuilderStageStyle {
    height: 100vh;
    padding: 18px;
    overflow: auto;
  }

  q-style pageBuilderStatusStyle {
    fontSize: 12px;
    fontWeight: 900;
    textTransform: uppercase;
    letterSpacing: .08em;
    color: #1d4ed8;
    background: #dbeafe;
    border: 1px solid #bfdbfe;
    borderRadius: 999px;
    padding: 8px 11px;
  }

  q-style pageBuilderPaletteBodyStyle {
    display: grid;
    gap: 10px;
    border: 0;
    borderRadius: 0;
    background: transparent;
    boxShadow: none;
    padding: 10px 16px 18px;
  }

  q-style pageBuilderPaletteButtonStyle {
    display: block;
    position: relative;
    minHeight: 76px;
    padding: 0;
    borderRadius: 18px;
    background: white;
    border: 1px solid rgba(148,163,184,.3);
    boxShadow: 0 12px 26px rgba(0,0,0,.18);
    cursor: grab;
    overflow: hidden;
  }

  q-style pageBuilderPalettePreviewStyle {
    minHeight: 76px;
    padding: 14px;
    background: linear-gradient(135deg,#ffffff,#eef6ff);
    borderLeft: 5px solid #2563eb;
  }

  q-style pageBuilderDialogStyle {
    border: 0;
    padding: 0;
    background: transparent;
    borderRadius: 24px;
  }

  q-style pageBuilderDialogCardStyle {
    background: #f8fafc;
    border: 1px solid rgba(148,163,184,.45);
    borderRadius: 24px;
    boxShadow: 0 36px 120px rgba(15,23,42,.38);
    overflow: hidden;
  }

  q-style pageBuilderDialogHeadStyle {
    display: flex;
    justifyContent: space-between;
    gap: 18px;
    alignItems: flex-start;
    padding: 18px 22px;
    background: white;
    borderBottom: 1px solid #dbe4f0;
  }

  q-style pageBuilderIconButtonStyle {
    width: 34px;
    height: 34px;
    border: 0;
    borderRadius: 999px;
    background: #eef2ff;
    color: #1e293b;
    fontSize: 23px;
    lineHeight: 1;
    cursor: pointer;
  }

  q-style pageBuilderFileBodyStyle {
    padding: 14px 18px 18px;
    minHeight: 360px;
  }

  q-style pageBuilderFileActionsStyle {
    display: flex;
    alignItems: center;
    justifyContent: flex-end;
    gap: 10px;
    padding: 14px 22px 18px;
    borderTop: 1px solid #dbe4f0;
    background: #fff;
  }

  q-default-theme pageBuilderTheme {
    .pb-app { pageBuilderAppStyle }
    .pb-toolbar { pageBuilderToolbarStyle }
    .pb-brand { pageBuilderBrandStyle }
    .pb-logo { pageBuilderLogoStyle }
    .pb-brand h1 { pageBuilderTitleStyle }
    .pb-brand p { pageBuilderCopyStyle }
    .pb-actions { pageBuilderActionRowStyle }
    .pb-action { pageBuilderActionStyle }
    .pb-action.primary { pageBuilderPrimaryActionStyle }
    .pb-action.secondary { pageBuilderSecondaryActionStyle }
    .pb-action.danger { pageBuilderDangerActionStyle }
    .pb-workspace { pageBuilderWorkspaceStyle }
    .pb-main { pageBuilderMainStyle }
    .pb-sidebar { pageBuilderSidebarStyle }
    .pb-sidebar-head { pageBuilderSidebarHeadStyle }
    .pb-sidebar h2 { pageBuilderSectionTitleStyle }
    .pb-sidebar p { pageBuilderCopyStyle }
    .pb-canvas-shell { pageBuilderPanelStyle }
    .pb-export-panel { pageBuilderPanelStyle }
    .pb-canvas-meta { pageBuilderPanelHeadStyle }
    .pb-export-head { pageBuilderPanelHeadStyle }
    .pb-canvas-meta h2 { pageBuilderSectionTitleStyle }
    .pb-export-head h2 { pageBuilderSectionTitleStyle }
    .pb-canvas-meta p { pageBuilderCopyStyle }
    .pb-export-head p { pageBuilderCopyStyle }
    .pb-stage { pageBuilderStageStyle }
    .pb-status { pageBuilderStatusStyle }
    .q-palette-body { pageBuilderPaletteBodyStyle }
    q-palette-toolbox-button { pageBuilderPaletteButtonStyle }
    .pb-palette-preview { pageBuilderPalettePreviewStyle }
    .pb-palette-preview h3 { pageBuilderSectionTitleStyle }
    .pb-palette-preview p { pageBuilderCopyStyle }
    .pb-palette-editor { pageBuilderDialogStyle }
    .pb-component-builder { pageBuilderDialogStyle }
    .pb-instance-editor { pageBuilderDialogStyle }
    .pb-file-dialog { pageBuilderDialogStyle }
    .pb-palette-editor-card { pageBuilderDialogCardStyle }
    .pb-component-builder-card { pageBuilderDialogCardStyle }
    .pb-instance-editor-card { pageBuilderDialogCardStyle }
    .pb-file-card { pageBuilderDialogCardStyle }
    .pb-palette-editor-head { pageBuilderDialogHeadStyle }
    .pb-component-builder-head { pageBuilderDialogHeadStyle }
    .pb-instance-editor-head { pageBuilderDialogHeadStyle }
    .pb-file-head { pageBuilderDialogHeadStyle }
    .pb-icon-button { pageBuilderIconButtonStyle }
    .pb-file-body { pageBuilderFileBodyStyle }
    .pb-file-actions { pageBuilderFileActionsStyle }
  }

  div.pb-app {
    page-builder-toolbar { }
    main.pb-workspace {
      page-builder-palette { }
      div.pb-main {
        page-builder-canvas { }
        page-builder-export-panel { }
      }
    }
    page-builder-palette-editor { }
    page-builder-component-builder { }
    page-builder-instance-editor { }
    page-builder-file-dialog { }
    page-builder-file-manager { }
    page-builder-folder-picker { }
    q-popup-menu {
      id: "pb-file-context-menu"
      popup-contents {
        div.pb-file-context-menu {
          id: "pb-file-context-menu-contents"
        }
      }
    }
    q-popup-menu {
      id: "pb-canvas-context-menu"
      popup-contents {
        div.pb-canvas-context-menu {
          id: "pb-canvas-context-menu-contents"
        }
      }
    }
  }
}
