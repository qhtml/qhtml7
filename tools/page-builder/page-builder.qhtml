        qhtml: "q-layout { width: \"100%\"; gap: \"14px\"; q-row { height: \"auto\"; q-col { width: \"1fr\"; q-layout { data-pb-slot: \"leftcolumn\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { leftcolumn } } } } } q-col { width: \"1fr\"; q-layout { data-pb-slot: \"middlecolumn\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { middlecolumn } } } } } q-col { width: \"1fr\"; q-layout { data-pb-slot: \"rightcolumn\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { rightcolumn } } } } } } } q-slot-default leftcolumn { text { Add left column content here. } } q-slot-default middlecolumn { text { Add middle column content here. } } q-slot-default rightcolumn { text { Add right column content here. } }"
