        qhtml: "q-style pbAsideBoxStyle { padding: 18px; borderRadius: 18px; background: #f8fafc; border: 1px solid #cbd5e1; color: #334155 } q-style pbAsideTitleStyle { marginTop: 0; color: #0f172a } q-style pbAsideBodyStyle { color: #475569; lineHeight: 1.5 } q-theme pbAsideBoxTheme { aside { pbAsideBoxStyle } h4 { pbAsideTitleStyle } p { pbAsideBodyStyle } } pbAsideBoxTheme { aside { h4 { q-layout { data-pb-slot: \"asideTitle\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { asideTitle } } } } } p { q-layout { data-pb-slot: \"asideBody\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { asideBody } } } } } q-layout { data-pb-slot: \"asideContent\"; width: \"100%\"; gap: \"8px\"; q-row { q-col { slot { asideContent } } } } } } q-slot-default asideTitle { text { Related } } q-slot-default asideBody { text { Add secondary context, links, or supporting notes here. } } q-slot-default asideContent { text { Add links or nested content here. } }"
        instance: "pb-aside-box { }"
