    this.currentLoop = 0;
    this.resetLoop();
    this.__qPropertyAnimationStarting = true;
    this.running = true;
    this.__qPropertyAnimationStarting = false;
    this.started();
    this.writeTargetValue(this.computeStepValue());
    this.startAnimationClock();
  }

  function stop() {
    this.running = false;
    this.stopAnimationClock();
    this.stopped();
  }

  function restart() {
    this.stop();
    this.start();
  }

  function step() {
    this.advance();
  }

  function end() {
    this.writeTargetValue(this.stripQuotes(this.to));
    this.running = false;
    this.stopAnimationClock();
    this.ended();
  }

  function finish() {
