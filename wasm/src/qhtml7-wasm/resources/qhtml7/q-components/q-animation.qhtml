q-component q-abstract-animation {
  q-signal started()
  q-signal stopped()
  q-signal stepped(value, currentStep, progress)
  q-signal ended()

  q-property running: false

  function normalizeBoolean(value, fallbackValue) {
    if (value === true || value === false) {
      return value;
    }
    if (value === 1 || value === "1") {
      return true;
    }
    if (value === 0 || value === "0") {
      return false;
    }
    var text = String(value == null ? "" : value).trim().toLowerCase();
    if (text === "true" || text === "yes" || text === "on") {
      return true;
    }
    if (text === "false" || text === "no" || text === "off" || text === "") {
      return false;
    }
    return Boolean(fallbackValue);
  }

  function start() {
    this.running = true;
    this.started();
  }

  function stop() {
    this.running = false;
    this.stopped();
  }

  function end() {
    this.running = false;
    this.ended();
  }

  function restart() {
    this.stop();
    this.start();
  }
}

q-component q-property-animation extends q-abstract-animation {
