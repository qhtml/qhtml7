q-component q-form-input-checkbox {
  q-property name: ""
  q-property label: ""
  q-property value: "1"

  label.q-form-field {
    span.q-form-label {
      text { ${this.label} }
    }
    input.q-form-checkbox {
      name: this.name
      type: "checkbox"
      value: this.value
    }
  }
}

q-component q-form-input-submit {
  q-property name: "submit"
  q-property label: "Submit"
  q-property value: "1"

  div.q-form-actions {
    button.q-form-submit {
      name: this.name
      type: "submit"
      value: this.value
      text { ${this.label} }
    }
  }
}
